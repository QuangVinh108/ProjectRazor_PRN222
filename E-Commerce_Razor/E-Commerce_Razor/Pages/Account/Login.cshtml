@page
@model E_Commerce_Razor.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />

<div class="login-container">
    <div class="login-bg"></div>

    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow login-card">
                    <div class="card-body p-5">
                        <h3 class="card-title text-center mb-4">Đăng Nhập</h3>

                        @* Hiển thị thông báo lỗi *@
                        @if (TempData["ErrorMessage"] != null)
                        {
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                @TempData["ErrorMessage"]
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        }

                        @* Hiển thị thông báo thành công *@
                        @if (TempData["SuccessMessage"] != null)
                        {
                            <div class="alert alert-success alert-dismissible fade show" role="alert">
                                <i class="bi bi-check-circle-fill me-2"></i>
                                @TempData["SuccessMessage"]
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        }

                        <p class="text-center text-muted mb-4">
                            Vào tài khoản của bạn để tiếp tục mua sắm
                        </p>

                        <form method="post" id="loginForm">
                            <input type="hidden" asp-for="Input.ReturnUrl" />

                            @if (!ViewData.ModelState.IsValid)
                            {
                                <div asp-validation-summary="All" class="alert alert-danger validation-error" role="alert"></div>
                            }

                            <div class="mb-3">
                                <label asp-for="Input.Username" class="form-label">
                                    <i class="bi bi-person-fill me-1"></i>Tên tài khoản
                                </label>
                                <input asp-for="Input.Username" class="form-control form-control-lg"
                                       placeholder="Nhập tên tài khoản" autofocus />
                                <span asp-validation-for="Input.Username" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Input.Password" class="form-label">
                                    <i class="bi bi-lock-fill me-1"></i>Mật khẩu
                                </label>
                                <input asp-for="Input.Password" class="form-control form-control-lg"
                                       placeholder="Nhập mật khẩu" />
                                <span asp-validation-for="Input.Password" class="text-danger small"></span>
                            </div>

                            <div class="mb-3 form-check">
                                <input type="checkbox" asp-for="Input.RememberMe" class="form-check-input" id="rememberMe">
                                <label class="form-check-label" for="rememberMe">Ghi nhớ đăng nhập</label>
                            </div>

                            <button type="submit" class="btn btn-primary btn-lg w-100 mb-3">
                                <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập
                            </button>
                        </form>

                        <div class="position-relative my-4">
                            <hr>
                            <span class="position-absolute top-50 start-50 translate-middle bg-white px-3 text-muted">
                                hoặc
                            </span>
                        </div>

                        <div class="d-flex justify-content-center w-100">
                            <div id="g_id_onload"
                                 data-client_id="477307811776-7f6ptpobvega67l3cd6ghin732dntka2.apps.googleusercontent.com"
                                 data-context="signin"
                                 data-ux_mode="popup"
                                 data-callback="handleCredentialResponse"
                                 data-auto_prompt="false">
                            </div>

                            <div class="g_id_signin"
                                 data-type="standard"
                                 data-shape="rectangular"
                                 data-theme="outline"
                                 data-text="signin_with"
                                 data-size="large"
                                 data-logo_alignment="left"
                                 data-width="340"> </div>
                        </div>

                        <p class="text-center mt-3">
                            Chưa có tài khoản?
                            <a asp-page="/Account/Register" class="text-decoration-none fw-bold">Đăng ký ngay</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://accounts.google.com/gsi/client" async defer></script>

<script>
    // ✅ XÓA LỖI VALIDATION KHI RELOAD TRANG
    window.addEventListener('load', function() {
        if (performance.navigation.type === 1 || performance.getEntriesByType('navigation')[0]?.type === 'reload') {
            const validationErrors = document.querySelectorAll('.validation-error, .field-validation-error');
            validationErrors.forEach(el => el.remove());

            const form = document.getElementById('loginForm');
            if (form) {
                form.classList.remove('was-validated');
            }
        }

        if (typeof google === 'undefined') {
            console.error('❌ Google Sign-In SDK failed to load');
        }
    });

    function handleCredentialResponse(response) {
        const antiforgeryToken = document.querySelector('input[name="__RequestVerificationToken"]').value;
        const form = document.createElement('form');
        form.method = 'POST';
        // Trỏ vào handler GoogleLogin của file Login.cshtml.cs
        form.action = '?handler=GoogleLogin';

        const tokenInput = document.createElement('input');
        tokenInput.type = 'hidden';
        tokenInput.name = '__RequestVerificationToken';
        tokenInput.value = antiforgeryToken;
        form.appendChild(tokenInput);

        const idTokenInput = document.createElement('input');
        idTokenInput.type = 'hidden';
        idTokenInput.name = 'idToken';
        idTokenInput.value = response.credential;
        form.appendChild(idTokenInput);

        const returnUrlInput = document.createElement('input');
        returnUrlInput.type = 'hidden';
        returnUrlInput.name = 'returnUrl';
        returnUrlInput.value = document.querySelector('input[name="ReturnUrl"]').value;
        form.appendChild(returnUrlInput);

        document.body.appendChild(form);
        form.submit();
    }
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}