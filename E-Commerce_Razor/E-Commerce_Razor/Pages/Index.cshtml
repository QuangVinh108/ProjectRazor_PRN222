@page
@model IndexModel
@{
    ViewData["Title"] = "TechShop - Mua sắm online";
}

<!-- ═══════════════════════════════════════════
     HERO SECTION
═══════════════════════════════════════════ -->
<section class="ts-hero">
    <!-- Animated gradient blobs -->
    <div class="ts-blob ts-b1"></div>
    <div class="ts-blob ts-b2"></div>
    <div class="ts-blob ts-b3"></div>

    <!-- Floating particles -->
    <div class="ts-particle" style="left:8%;top:22%;width:10px;height:10px;--pd:0s;--pc:rgba(79,70,229,.22)"></div>
    <div class="ts-particle" style="left:85%;top:16%;width:14px;height:14px;--pd:1.2s;--pc:rgba(236,72,153,.2)"></div>
    <div class="ts-particle" style="left:14%;top:64%;width:8px;height:8px;--pd:0.6s;--pc:rgba(59,130,246,.24)"></div>
    <div class="ts-particle" style="left:91%;top:54%;width:12px;height:12px;--pd:1.8s;--pc:rgba(16,185,129,.2)"></div>
    <div class="ts-particle" style="left:50%;top:8%;width:6px;height:6px;--pd:2.4s;--pc:rgba(245,158,11,.24)"></div>
    <div class="ts-particle" style="left:70%;top:79%;width:10px;height:10px;--pd:0.9s;--pc:rgba(79,70,229,.18)"></div>
    <div class="ts-particle" style="left:30%;top:88%;width:8px;height:8px;--pd:3s;--pc:rgba(236,72,153,.15)"></div>

    <div class="container-xl px-4 px-lg-5">
        <div class="row align-items-center ts-hero-row g-5">

            <!-- LEFT: Content -->
            <div class="col-lg-6 ts-reveal-up">
                <span class="ts-eyebrow">
                    <span class="ts-ey-dot"></span>
                    <i class="bi bi-stars me-1"></i> Uy tín #1 Việt Nam
                </span>
                <h1 class="ts-h1">
                    Mua sắm<br>
                    <span class="ts-grad-text" id="tsTypewriter"></span><span class="ts-cursor">|</span><br>
                    hàng đầu Việt Nam
                </h1>
                <p class="ts-lead">
                    Hàng ngàn sản phẩm điện tử chính hãng, giá tốt nhất thị trường —
                    giao nhanh 2h, bảo hành toàn diện, đổi trả dễ dàng.
                </p>
                <div class="ts-btn-row">
                    <a asp-page="/Shop/Index" class="ts-btn ts-btn-grad">
                        Khám phá ngay <i class="bi bi-arrow-right ms-2"></i>
                    </a>
                    <a asp-page="/Shop/Index" class="ts-btn ts-btn-outline">
                        <i class="bi bi-bag-check me-2"></i> Xem sản phẩm
                    </a>
                </div>
                <div class="ts-trust">
                    <div class="ts-ti">
                        <div class="ts-ti-icon ts-ti-blue"><i class="bi bi-shield-fill-check"></i></div>
                        <div>
                            <div class="ts-ti-label">Bảo hành</div>
                            <div class="ts-ti-val">12 tháng</div>
                        </div>
                    </div>
                    <div class="ts-trust-sep"></div>
                    <div class="ts-ti">
                        <div class="ts-ti-icon ts-ti-green"><i class="bi bi-truck"></i></div>
                        <div>
                            <div class="ts-ti-label">Giao hàng</div>
                            <div class="ts-ti-val">2–4h</div>
                        </div>
                    </div>
                    <div class="ts-trust-sep"></div>
                    <div class="ts-ti">
                        <div class="ts-ti-icon ts-ti-violet"><i class="bi bi-arrow-repeat"></i></div>
                        <div>
                            <div class="ts-ti-label">Đổi trả</div>
                            <div class="ts-ti-val">30 ngày</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- RIGHT: Image with 3D tilt + floating badges -->
            <div class="col-lg-6 ts-reveal-right">
                <div class="ts-img-wrap" id="tsTilt">
                    <div class="ts-glow-ring"></div>
                    <div class="ts-glow-ring ts-glow-r2"></div>
                    <img src="~/images/products/hero.png"
                         alt="Tech Shopping"
                         class="ts-hero-img"
                         loading="eager"
                         onerror="this.src='https://images.unsplash.com/photo-1604548530945-fbdce3e76bc4?w=700&q=80'">
                    <div class="ts-flt ts-flt1">
                        <span class="ts-flt-i ts-flt-y"><i class="bi bi-lightning-charge-fill"></i></span>
                        <div class="ts-flt-txt"><span>Flash Sale</span><strong>−50%</strong></div>
                    </div>
                    <div class="ts-flt ts-flt2">
                        <span class="ts-flt-i ts-flt-b"><i class="bi bi-star-fill"></i></span>
                        <div class="ts-flt-txt"><span>4.9 / 5.0</span><strong>25k+ đánh giá</strong></div>
                    </div>
                    <div class="ts-flt ts-flt3">
                        <span class="ts-flt-i ts-flt-g"><i class="bi bi-truck-front-fill"></i></span>
                        <div class="ts-flt-txt"><span>Freeship</span><strong>Toàn quốc</strong></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Scroll indicator -->
    <div class="ts-scroll-ind">
        <div class="ts-scroll-dot"></div>
    </div>
</section>

<!-- ═══════════════════════════════════════════
     MARQUEE STRIP
═══════════════════════════════════════════ -->
<div class="ts-mq">
    <div class="ts-mq-track">
        <span class="ts-mq-item"><i class="bi bi-shield-fill-check"></i> Chính hãng 100%</span>
        <span class="ts-mq-item"><i class="bi bi-truck"></i> Giao nhanh 2h</span>
        <span class="ts-mq-item"><i class="bi bi-arrow-repeat"></i> Đổi trả 30 ngày</span>
        <span class="ts-mq-item"><i class="bi bi-credit-card"></i> Trả góp 0%</span>
        <span class="ts-mq-item"><i class="bi bi-trophy-fill"></i> Top 1 Việt Nam</span>
        <span class="ts-mq-item"><i class="bi bi-lightning-charge-fill"></i> Flash Sale hàng ngày</span>
        <span class="ts-mq-item"><i class="bi bi-gift-fill"></i> Quà tặng hấp dẫn</span>
        <span class="ts-mq-item"><i class="bi bi-headset"></i> Hỗ trợ 24/7</span>
        <!-- Duplicate for seamless loop -->
        <span class="ts-mq-item"><i class="bi bi-shield-fill-check"></i> Chính hãng 100%</span>
        <span class="ts-mq-item"><i class="bi bi-truck"></i> Giao nhanh 2h</span>
        <span class="ts-mq-item"><i class="bi bi-arrow-repeat"></i> Đổi trả 30 ngày</span>
        <span class="ts-mq-item"><i class="bi bi-credit-card"></i> Trả góp 0%</span>
        <span class="ts-mq-item"><i class="bi bi-trophy-fill"></i> Top 1 Việt Nam</span>
        <span class="ts-mq-item"><i class="bi bi-lightning-charge-fill"></i> Flash Sale hàng ngày</span>
        <span class="ts-mq-item"><i class="bi bi-gift-fill"></i> Quà tặng hấp dẫn</span>
        <span class="ts-mq-item"><i class="bi bi-headset"></i> Hỗ trợ 24/7</span>
    </div>
</div>

<!-- ═══════════════════════════════════════════
     CATEGORIES SECTION
═══════════════════════════════════════════ -->
<section class="ts-section ts-bg-gray">
    <div class="container-xl px-4 px-lg-5">
        <div class="ts-sec-hdr ts-reveal-up">
            <span class="ts-sec-label">DANH MỤC</span>
            <h2 class="ts-sec-title">Mua sắm theo nhu cầu</h2>
            <p class="ts-sec-sub">Khám phá hàng nghìn sản phẩm chính hãng trong từng danh mục</p>
        </div>
        <div class="row g-4">
            <div class="col-lg-3 col-md-6 ts-reveal-up" style="animation-delay:.05s">
                <a asp-page="/Shop/Index" asp-route-category="Điện thoại" class="ts-cat ts-cat-blue">
                    <div class="ts-cat-icon ts-cat-icon-blue"><i class="bi bi-phone-fill"></i></div>
                    <h4 class="ts-cat-name">Điện thoại</h4>
                    <p class="ts-cat-sub">iPhone, Samsung, Xiaomi...</p>
                    <div class="ts-cat-foot">
                        <span class="ts-cat-cnt">1,200+ sản phẩm</span>
                        <i class="bi bi-arrow-right ts-cat-arr"></i>
                    </div>
                </a>
            </div>
            <div class="col-lg-3 col-md-6 ts-reveal-up" style="animation-delay:.15s">
                <a asp-page="/Shop/Index" asp-route-category="Laptop" class="ts-cat ts-cat-violet">
                    <div class="ts-cat-icon ts-cat-icon-violet"><i class="bi bi-laptop-fill"></i></div>
                    <h4 class="ts-cat-name">Laptop</h4>
                    <p class="ts-cat-sub">MacBook, Dell, Asus, HP...</p>
                    <div class="ts-cat-foot">
                        <span class="ts-cat-cnt">850+ sản phẩm</span>
                        <i class="bi bi-arrow-right ts-cat-arr"></i>
                    </div>
                </a>
            </div>
            <div class="col-lg-3 col-md-6 ts-reveal-up" style="animation-delay:.25s">
                <a asp-page="/Shop/Index" asp-route-category="Linh kiện" class="ts-cat ts-cat-emerald">
                    <div class="ts-cat-icon ts-cat-icon-emerald"><i class="bi bi-cpu-fill"></i></div>
                    <h4 class="ts-cat-name">Linh kiện</h4>
                    <p class="ts-cat-sub">CPU, RAM, VGA, SSD...</p>
                    <div class="ts-cat-foot">
                        <span class="ts-cat-cnt">2,400+ sản phẩm</span>
                        <i class="bi bi-arrow-right ts-cat-arr"></i>
                    </div>
                </a>
            </div>
            <div class="col-lg-3 col-md-6 ts-reveal-up" style="animation-delay:.35s">
                <a asp-page="/Shop/Index" asp-route-category="Phụ kiện" class="ts-cat ts-cat-amber">
                    <div class="ts-cat-icon ts-cat-icon-amber"><i class="bi bi-headphones"></i></div>
                    <h4 class="ts-cat-name">Phụ kiện</h4>
                    <p class="ts-cat-sub">Tai nghe, chuột, bàn phím...</p>
                    <div class="ts-cat-foot">
                        <span class="ts-cat-cnt">3,100+ sản phẩm</span>
                        <i class="bi bi-arrow-right ts-cat-arr"></i>
                    </div>
                </a>
            </div>
        </div>
    </div>
</section>

