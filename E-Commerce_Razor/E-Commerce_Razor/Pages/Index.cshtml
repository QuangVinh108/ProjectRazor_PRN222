@* ═══════════════════════════════════════════
   SCRIPTS
═══════════════════════════════════════════ *@
@section Scripts {
    <script>
        (function () {
          'use strict';

          /* ── 1. SCROLL REVEAL ── */
          var revealEls = document.querySelectorAll('.ts-reveal-up, .ts-reveal-right');
          if ('IntersectionObserver' in window) {
            var revealObs = new IntersectionObserver(function (entries) {
              entries.forEach(function (e) {
                if (e.isIntersecting) {
                  var el = e.target;
                  var delay = el.style.animationDelay || '0s';
                  var ms = parseFloat(delay) * 1000;
                  setTimeout(function () { el.classList.add('ts-revealed'); }, ms);
                  revealObs.unobserve(el);
                }
              });
            }, { threshold: 0.12 });
            revealEls.forEach(function (el) { revealObs.observe(el); });
          } else {
            revealEls.forEach(function (el) { el.classList.add('ts-revealed'); });
          }

          /* ── 2. TYPEWRITER ── */
          var words = ['điện thoại', 'laptop', 'linh kiện', 'phụ kiện'];
          var el = document.getElementById('tsTypewriter');
          if (el) {
            var wIdx = 0, charIdx = 0, deleting = false;
            function typeStep() {
              var word = words[wIdx];
              if (!deleting && charIdx < word.length) {
                el.textContent = word.slice(0, ++charIdx);
                setTimeout(typeStep, 85);
              } else if (!deleting && charIdx === word.length) {
                deleting = true;
                setTimeout(typeStep, 2200);
              } else if (deleting && charIdx > 0) {
                el.textContent = word.slice(0, --charIdx);
                setTimeout(typeStep, 45);
              } else {
                deleting = false;
                wIdx = (wIdx + 1) % words.length;
                setTimeout(typeStep, 300);
              }
            }
            typeStep();
          }

          /* ── 3. COUNTER ANIMATION ── */
          var statNums = document.querySelectorAll('.ts-stat-num[data-target]');
          if (statNums.length && 'IntersectionObserver' in window) {
            var statObs = new IntersectionObserver(function (entries) {
              entries.forEach(function (e) {
                if (!e.isIntersecting) return;
                var numEl = e.target;
                var target = parseFloat(numEl.getAttribute('data-target'));
                var suffix = numEl.getAttribute('data-suffix') || '';
                var isFloat = numEl.getAttribute('data-float') === 'true';
                var duration = 2200;
                var startTime = null;
                function tick(now) {
                  if (!startTime) startTime = now;
                  var progress = Math.min((now - startTime) / duration, 1);
                  var eased = 1 - Math.pow(1 - progress, 4);
                  var current = eased * target;
                  numEl.textContent = (isFloat ? current.toFixed(1) : Math.floor(current)) + suffix;
                  if (progress < 1) requestAnimationFrame(tick);
                }
                requestAnimationFrame(tick);
                statObs.unobserve(numEl);
              });
            }, { threshold: 0.3 });
            statNums.forEach(function (el) { statObs.observe(el); });
          }

          /* ── 4. 3D TILT ON HERO IMAGE ── */
          var tiltEl = document.getElementById('tsTilt');
          if (tiltEl) {
            tiltEl.addEventListener('mousemove', function (e) {
              var r = tiltEl.getBoundingClientRect();
              var px = (e.clientX - r.left) / r.width - 0.5;
              var py = (e.clientY - r.top) / r.height - 0.5;
              tiltEl.style.transform = 'perspective(1000px) rotateX(' + (-py * 12) + 'deg) rotateY(' + (px * 12) + 'deg)';
            });
            tiltEl.addEventListener('mouseleave', function () {
              tiltEl.style.transform = 'perspective(1000px) rotateX(0) rotateY(0)';
              tiltEl.style.transition = 'transform .5s ease';
              setTimeout(function () { tiltEl.style.transition = ''; }, 500);
            });
          }

          /* ── 5. NAVBAR SHADOW ON SCROLL ── */
          window.addEventListener('scroll', function () {
            var nav = document.querySelector('.navbar, header nav, nav.navbar');
            if (!nav) return;
            if (window.scrollY > 30) {
              nav.style.boxShadow = '0 4px 24px rgba(0,0,0,.08)';
              nav.style.backdropFilter = 'blur(20px)';
            } else {
              nav.style.boxShadow = '';
            }
          }, { passive: true });

        })();
    </script>
}
