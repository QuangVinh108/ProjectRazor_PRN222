@* ═══════════════════════════════════════════
   STYLES — nhúng thẳng vào trang
   (hoặc chuyển sang wwwroot/css/homepage.css)
═══════════════════════════════════════════ *@
@section Styles {
    <style>
        /* ── Tokens ── */
        :root {
            --ts-w: #fff;
            --ts-bg: #f8fafc;
            --ts-border: #e2e8f0;
            --ts-dark: #0f172a;
            --ts-text: #334155;
            --ts-muted: #64748b;
            --ts-blue: #3b82f6;
            --ts-blue-lt: #eff6ff;
            --ts-violet: #7c3aed;
            --ts-violet-lt: #f5f3ff;
            --ts-em: #10b981;
            --ts-em-lt: #ecfdf5;
            --ts-amb: #f59e0b;
            --ts-amb-lt: #fffbeb;
            --ts-pink: #ec4899;
            --ts-pink-lt: #fdf2f8;
            --ts-teal: #0891b2;
            --ts-teal-lt: #ecfeff;
            --ts-g: linear-gradient(135deg,#4f46e5 0%,#7c3aed 55%,#ec4899 100%);
            --ts-g-blue: linear-gradient(135deg,#3b82f6,#6366f1);
            --ts-g-vio: linear-gradient(135deg,#7c3aed,#a855f7);
            --ts-g-em: linear-gradient(135deg,#10b981,#059669);
            --ts-g-amb: linear-gradient(135deg,#f59e0b,#ef4444);
            --ts-sh-sm: 0 2px 8px rgba(0,0,0,.07),0 8px 24px rgba(0,0,0,.06);
            --ts-sh-md: 0 4px 20px rgba(0,0,0,.09),0 16px 48px rgba(0,0,0,.07);
            --ts-sh-lg: 0 8px 40px rgba(0,0,0,.13),0 28px 72px rgba(0,0,0,.09);
            --ts-r: 20px;
        }

        /* ── Reset ── */
        .ts-hero, .ts-section, .ts-mq, .ts-cta-card, .ts-stat, .ts-feat, .ts-cat {
            box-sizing: border-box;
        }

        /* ══════════════════════
           HERO
        ══════════════════════ */
        .ts-hero {
            position: relative;
            overflow: hidden;
            background: #fff;
            padding: 120px 0 100px;
            min-height: 92vh;
            display: flex;
            align-items: center;
        }

        /* blobs */
        .ts-blob {
            position: absolute;
            border-radius: 50%;
            filter: blur(90px);
            pointer-events: none;
        }

        .ts-b1 {
            width: 640px;
            height: 640px;
            top: -200px;
            left: -120px;
            background: radial-gradient(circle,rgba(79,70,229,.14) 0%,transparent 70%);
            animation: ts-blob-move 10s ease-in-out infinite;
        }

        .ts-b2 {
            width: 560px;
            height: 560px;
            bottom: -200px;
            right: -120px;
            background: radial-gradient(circle,rgba(236,72,153,.12) 0%,transparent 70%);
            animation: ts-blob-move 12s ease-in-out infinite reverse;
            animation-delay: 2s;
        }

        .ts-b3 {
            width: 420px;
            height: 420px;
            top: 40%;
            left: 45%;
            transform: translate(-50%,-50%);
            background: radial-gradient(circle,rgba(59,130,246,.09) 0%,transparent 70%);
            animation: ts-blob-scale 8s ease-in-out infinite;
            animation-delay: 1s;
        }
        @@keyframes ts-blob-move {
            0%,100%

        {
            transform: translate(0,0) scale(1);
        }

        33% {
            transform: translate(30px,-20px) scale(1.1);
        }

        66% {
            transform: translate(-20px,25px) scale(0.95);
        }

        }
        @@keyframes ts-blob-scale {
            0%,100%

        {
            transform: translate(-50%,-50%) scale(1);
        }

        50% {
            transform: translate(-50%,-50%) scale(1.18);
        }

        }

        /* particles */
        .ts-particle {
            position: absolute;
            border-radius: 50%;
            background: var(--pc,rgba(79,70,229,.2));
            animation: ts-particle-float 4s ease-in-out infinite;
            animation-delay: var(--pd,0s);
            pointer-events: none;
        }
        @@keyframes ts-particle-float {
            0%,100%

        {
            transform: translateY(0) scale(1);
            opacity: .4;
        }

        50% {
            transform: translateY(-22px) scale(1.2);
            opacity: .85;
        }

        }

        /* hero layout */
        .ts-hero-row {
            min-height: 75vh;
            align-items: center;
        }

        /* eyebrow */
        .ts-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: linear-gradient(135deg,#eff6ff,#f5f3ff);
            border: 1px solid #ddd6fe;
            color: var(--ts-violet);
            padding: 7px 16px;
            border-radius: 50px;
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 24px;
        }

        .ts-ey-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--ts-violet);
            display: inline-block;
            animation: ts-pulse 2s ease-in-out infinite;
        }
        @@keyframes ts-pulse {
            0%,100%

        {
            opacity: 1;
            transform: scale(1);
        }

        50% {
            opacity: .3;
            transform: scale(1.6);
        }

        }

        /* headline */
        .ts-h1 {
            font-size: clamp(2.3rem,4.6vw,3.8rem);
            font-weight: 900;
            line-height: 1.08;
            color: var(--ts-dark);
            margin-bottom: 22px;
            letter-spacing: -2px;
        }

        .ts-grad-text {
            background: var(--ts-g);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            background-size: 200% auto;
            animation: ts-grad-shift 4s linear infinite;
        }
        @@keyframes ts-grad-shift {
            0%

        {
            background-position: 0% 50%;
        }

        50% {
            background-position: 100% 50%;
        }

        100% {
            background-position: 0% 50%;
        }

        }

        .ts-cursor {
            display: inline-block;
            border-right: 3px solid #7c3aed;
            margin-left: 2px;
            animation: ts-blink .7s steps(1) infinite;
            -webkit-text-fill-color: #7c3aed;
        }
        @@keyframes ts-blink {
            0%,100%

        {
            opacity: 1;
        }

        50% {
            opacity: 0;
        }

        }

        .ts-lead {
            font-size: 17px;
            color: var(--ts-muted);
            line-height: 1.8;
            max-width: 470px;
            margin-bottom: 36px;
        }

        /* buttons */
        .ts-btn-row {
            display: flex;
            gap: 14px;
            flex-wrap: wrap;
            margin-bottom: 40px;
        }

        .ts-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 14px 30px;
            border-radius: 50px;
            font-size: 15px;
            font-weight: 700;
            text-decoration: none;
            transition: all .25s cubic-bezier(.34,1.56,.64,1);
        }

        .ts-btn-grad {
            background: var(--ts-g);
            color: #fff;
            box-shadow: 0 8px 28px rgba(79,70,229,.38);
        }

            .ts-btn-grad:hover {
                transform: translateY(-4px) scale(1.03);
                color: #fff;
                box-shadow: 0 16px 40px rgba(79,70,229,.5);
            }

        .ts-btn-outline {
            background: #fff;
            color: var(--ts-dark);
            border: 2px solid var(--ts-border);
            box-shadow: 0 2px 8px rgba(0,0,0,.06);
        }

            .ts-btn-outline:hover {
                border-color: #c4b5fd;
                color: var(--ts-violet);
                transform: translateY(-4px);
                box-shadow: var(--ts-sh-sm);
            }

        /* trust bar */
        .ts-trust {
            display: flex;
            align-items: center;
            gap: 20px;
            flex-wrap: wrap;
            background: #fff;
            border: 1px solid var(--ts-border);
            border-radius: 16px;
            padding: 16px 22px;
            width: fit-content;
            box-shadow: 0 2px 8px rgba(0,0,0,.06);
        }

        .ts-trust-sep {
            width: 1px;
            height: 38px;
            background: var(--ts-border);
            flex-shrink: 0;
        }

        .ts-ti {
            display: flex;
            align-items: center;
            gap: 10px;
            white-space: nowrap;
        }

        .ts-ti-icon {
            width: 38px;
            height: 38px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 17px;
            flex-shrink: 0;
        }

        .ts-ti-blue {
            background: var(--ts-blue-lt);
            color: var(--ts-blue);
        }

        .ts-ti-green {
            background: var(--ts-em-lt);
            color: var(--ts-em);
        }

        .ts-ti-violet {
            background: var(--ts-violet-lt);
            color: var(--ts-violet);
        }

        .ts-ti-label {
            font-size: 11px;
            color: var(--ts-muted);
        }

        .ts-ti-val {
            font-size: 13px;
            font-weight: 700;
            color: var(--ts-dark);
        }

        /* image wrap */
        .ts-img-wrap {
            position: relative;
            width: 100%;
            max-width: 550px;
            margin: 0 auto;
            transform-style: preserve-3d;
        }

        .ts-glow-ring {
            position: absolute;
            inset: -24px;
            border-radius: 42px;
            background: conic-gradient(from 0deg,rgba(79,70,229,.22),rgba(236,72,153,.18),rgba(59,130,246,.12),rgba(79,70,229,.22));
            animation: ts-ring-spin 20s linear infinite;
            z-index: 0;
        }

        .ts-glow-r2 {
            inset: -14px;
            background: conic-gradient(from 180deg,rgba(236,72,153,.14),rgba(79,70,229,.1),transparent,rgba(236,72,153,.14));
            animation: ts-ring-spin 14s linear infinite reverse;
        }
        @@keyframes ts-ring-spin {
            from

        {
            transform: rotate(0deg);
        }

        to {
            transform: rotate(360deg);
        }

        }

        .ts-hero-img {
            width: 100%;
            border-radius: 28px;
            display: block;
            aspect-ratio: 4/3;
            object-fit: cover;
            position: relative;
            z-index: 1;
            box-shadow: 0 24px 64px rgba(15,23,42,.16),0 6px 18px rgba(15,23,42,.08);
        }

        /* floating badges */
        .ts-flt {
            position: absolute;
            z-index: 3;
            display: flex;
            align-items: center;
            gap: 10px;
            background: rgba(255,255,255,.9);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255,255,255,.95);
            border-radius: 50px;
            padding: 10px 18px 10px 10px;
            box-shadow: 0 10px 36px rgba(15,23,42,.13);
            white-space: nowrap;
        }

        .ts-flt-i {
            width: 38px;
            height: 38px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            flex-shrink: 0;
        }

        .ts-flt-y {
            background: #fef9c3;
            color: #92400e;
        }

        .ts-flt-b {
            background: var(--ts-blue-lt);
            color: var(--ts-blue);
        }

        .ts-flt-g {
            background: var(--ts-em-lt);
            color: var(--ts-em);
        }

        .ts-flt-txt {
            display: flex;
            flex-direction: column;
        }

            .ts-flt-txt span {
                font-size: 11px;
                color: var(--ts-muted);
            }

            .ts-flt-txt strong {
                font-size: 13px;
                font-weight: 700;
                color: var(--ts-dark);
            }

        .ts-flt1 {
            top: 7%;
            left: -28px;
            animation: ts-float-badge 3.5s ease-in-out infinite;
        }

        .ts-flt2 {
            top: 44%;
            right: -28px;
            animation: ts-float-badge 3.5s ease-in-out infinite;
            animation-delay: .9s;
        }

        .ts-flt3 {
            bottom: 7%;
            left: 9%;
            animation: ts-float-badge 3.5s ease-in-out infinite;
            animation-delay: 1.8s;
        }
        @@keyframes ts-float-badge {
            0%,100%

        {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-12px);
        }

        }

        /* scroll indicator */
        .ts-scroll-ind {
            position: absolute;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            width: 26px;
            height: 44px;
            border: 2px solid #e2e8f0;
            border-radius: 50px;
            display: flex;
            align-items: flex-start;
            justify-content: center;
            padding-top: 6px;
        }

        .ts-scroll-dot {
            width: 5px;
            height: 10px;
            border-radius: 50px;
            background: var(--ts-g);
            animation: ts-scroll-anim 1.6s ease-in-out infinite;
        }
        @@keyframes ts-scroll-anim {
            0%,100%

        {
            transform: translateY(0);
            opacity: 1;
        }

        80% {
            transform: translateY(14px);
            opacity: .2;
        }

        }

        /* ══════════════════════
           MARQUEE
        ══════════════════════ */
        .ts-mq {
            overflow: hidden;
            background: #0f172a;
            border-top: 1px solid #1e293b;
            border-bottom: 1px solid #1e293b;
            padding: 14px 0;
        }

        .ts-mq-track {
            display: flex;
            white-space: nowrap;
            width: max-content;
            animation: ts-mq-scroll 28s linear infinite;
        }
        @@keyframes ts-mq-scroll {
            from

        {
            transform: translateX(0);
        }

        to {
            transform: translateX(-50%);
        }

        }

        .ts-mq-item {
            display: inline-flex;
            align-items: center;
            gap: 9px;
            padding: 0 36px;
            font-size: 13px;
            font-weight: 600;
            color: #94a3b8;
            border-right: 1px solid #1e293b;
            letter-spacing: .3px;
        }

            .ts-mq-item i {
                font-size: 15px;
            }

        /* ══════════════════════
           SECTIONS COMMON
        ══════════════════════ */
        .ts-section {
            padding: 100px 0;
        }

        .ts-bg-white {
            background: #fff;
        }

        .ts-bg-gray {
            background: #f8fafc;
        }

        .ts-sec-hdr {
            text-align: center;
            margin-bottom: 56px;
        }

        .ts-sec-label {
            display: inline-block;
            font-size: 10.5px;
            font-weight: 700;
            letter-spacing: 2.5px;
            text-transform: uppercase;
            color: var(--ts-violet);
            background: var(--ts-violet-lt);
            border: 1px solid #ddd6fe;
            padding: 4px 14px;
            border-radius: 50px;
            margin-bottom: 14px;
        }

        .ts-sec-label-lt {
            color: #c4b5fd;
            background: rgba(124,58,237,.2);
            border-color: rgba(124,58,237,.3);
        }

        .ts-sec-title {
            font-size: clamp(1.9rem,3.2vw,2.5rem);
            font-weight: 900;
            color: var(--ts-dark);
            letter-spacing: -1px;
            line-height: 1.15;
        }

        .ts-sec-title-wh {
            color: #fff;
        }

        .ts-sec-sub {
            font-size: 16px;
            color: var(--ts-muted);
            margin-top: 10px;
        }

        /* ══════════════════════
           CATEGORIES
        ══════════════════════ */
        .ts-cat {
            display: flex;
            flex-direction: column;
            gap: 14px;
            background: #fff;
            border: 1px solid var(--ts-border);
            border-radius: var(--ts-r);
            padding: 28px 24px 22px;
            text-decoration: none;
            height: 100%;
            transition: all .3s cubic-bezier(.34,1.56,.64,1);
            position: relative;
            overflow: hidden;
        }

            .ts-cat::before {
                content: '';
                position: absolute;
                inset: 0;
                opacity: 0;
                border-radius: var(--ts-r);
                transition: opacity .3s;
            }

            .ts-cat:hover {
                transform: translateY(-10px);
                box-shadow: var(--ts-sh-lg);
                border-color: transparent;
            }

                .ts-cat:hover::before {
                    opacity: 1;
                }

        .ts-cat-blue {
            border-top: 3px solid var(--ts-blue);
        }

        .ts-cat-violet {
            border-top: 3px solid var(--ts-violet);
        }

        .ts-cat-emerald {
            border-top: 3px solid var(--ts-em);
        }

        .ts-cat-amber {
            border-top: 3px solid var(--ts-amb);
        }

        .ts-cat-blue::before {
            background: linear-gradient(145deg,rgba(59,130,246,.05),transparent);
        }

        .ts-cat-violet::before {
            background: linear-gradient(145deg,rgba(124,58,237,.05),transparent);
        }

        .ts-cat-emerald::before {
            background: linear-gradient(145deg,rgba(16,185,129,.05),transparent);
        }

        .ts-cat-amber::before {
            background: linear-gradient(145deg,rgba(245,158,11,.05),transparent);
        }

        .ts-cat-icon {
            width: 62px;
            height: 62px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            flex-shrink: 0;
            transition: transform .3s;
        }

        .ts-cat:hover .ts-cat-icon {
            transform: rotate(-8deg) scale(1.1);
        }

        .ts-cat-icon-blue {
            background: var(--ts-blue-lt);
            color: var(--ts-blue);
        }

        .ts-cat-icon-violet {
            background: var(--ts-violet-lt);
            color: var(--ts-violet);
        }

        .ts-cat-icon-emerald {
            background: var(--ts-em-lt);
            color: var(--ts-em);
        }

        .ts-cat-icon-amber {
            background: var(--ts-amb-lt);
            color: var(--ts-amb);
        }

        .ts-cat-name {
            font-size: 17px;
            font-weight: 800;
            color: var(--ts-dark);
            margin: 0;
        }

        .ts-cat-sub {
            font-size: 13px;
            color: var(--ts-muted);
            margin: 0;
        }

        .ts-cat-foot {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding-top: 14px;
            border-top: 1px solid var(--ts-border);
            margin-top: auto;
        }

        .ts-cat-cnt {
            font-size: 12px;
            font-weight: 600;
            color: var(--ts-muted);
        }

        .ts-cat-arr {
            font-size: 16px;
            color: var(--ts-muted);
            transition: all .3s;
        }

        .ts-cat:hover .ts-cat-arr {
            transform: translateX(6px);
            color: var(--ts-violet);
        }

        /* ══════════════════════
           FEATURES
        ══════════════════════ */
        .ts-feat {
            background: #fff;
            border: 1px solid var(--ts-border);
            border-radius: var(--ts-r);
            padding: 32px 26px;
            height: 100%;
            position: relative;
            overflow: hidden;
            transition: all .3s;
        }

            .ts-feat::after {
                content: '';
                position: absolute;
                inset: 0;
                opacity: 0;
                border-radius: var(--ts-r);
                transition: opacity .3s;
            }

            .ts-feat:hover {
                transform: translateY(-6px) scale(1.02);
                box-shadow: var(--ts-sh-md);
            }

                .ts-feat:hover::after {
                    opacity: 1;
                }

        .ts-feat-blue {
            border-left: 3px solid var(--ts-blue);
        }

        .ts-feat-violet {
            border-left: 3px solid var(--ts-violet);
        }

        .ts-feat-emerald {
            border-left: 3px solid var(--ts-em);
        }

        .ts-feat-amber {
            border-left: 3px solid var(--ts-amb);
        }

        .ts-feat-pink {
            border-left: 3px solid var(--ts-pink);
        }

        .ts-feat-teal {
            border-left: 3px solid var(--ts-teal);
        }

        .ts-feat-blue::after {
            background: linear-gradient(145deg,rgba(59,130,246,.04),transparent 60%);
        }

        .ts-feat-violet::after {
            background: linear-gradient(145deg,rgba(124,58,237,.04),transparent 60%);
        }

        .ts-feat-emerald::after {
            background: linear-gradient(145deg,rgba(16,185,129,.04),transparent 60%);
        }

        .ts-feat-amber::after {
            background: linear-gradient(145deg,rgba(245,158,11,.04),transparent 60%);
        }

        .ts-feat-pink::after {
            background: linear-gradient(145deg,rgba(236,72,153,.04),transparent 60%);
        }

        .ts-feat-teal::after {
            background: linear-gradient(145deg,rgba(8,145,178,.04),transparent 60%);
        }

        .ts-feat-icon {
            width: 54px;
            height: 54px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            margin-bottom: 18px;
            animation: ts-icon-rock 4s ease-in-out infinite;
        }
        @@keyframes ts-icon-rock {
            0%,100%

        {
            transform: rotate(0);
        }

        25% {
            transform: rotate(6deg);
        }

        75% {
            transform: rotate(-6deg);
        }

        }

        .ts-feat-icon-blue {
            background: var(--ts-blue-lt);
            color: var(--ts-blue);
        }

        .ts-feat-icon-violet {
            background: var(--ts-violet-lt);
            color: var(--ts-violet);
        }

        .ts-feat-icon-emerald {
            background: var(--ts-em-lt);
            color: var(--ts-em);
        }

        .ts-feat-icon-amber {
            background: var(--ts-amb-lt);
            color: var(--ts-amb);
        }

        .ts-feat-icon-pink {
            background: var(--ts-pink-lt);
            color: var(--ts-pink);
        }

        .ts-feat-icon-teal {
            background: var(--ts-teal-lt);
            color: var(--ts-teal);
        }

        .ts-feat-title {
            font-size: 16px;
            font-weight: 800;
            color: var(--ts-dark);
            margin: 0 0 10px;
        }

        .ts-feat-desc {
            font-size: 13.5px;
            color: var(--ts-muted);
            line-height: 1.7;
            margin: 0;
        }

        /* ══════════════════════
           STATS
        ══════════════════════ */
        .ts-stats-sec {
            padding: 100px 0;
            position: relative;
            overflow: hidden;
            background: linear-gradient(135deg,#1e1b4b 0%,#0f172a 50%,#1a0f2e 100%);
        }

        .ts-stats-grid-bg {
            position: absolute;
            inset: 0;
            background-image: linear-gradient(rgba(79,70,229,.07) 1px,transparent 1px), linear-gradient(90deg,rgba(79,70,229,.07) 1px,transparent 1px);
            background-size: 64px 64px;
            animation: ts-grid-move 20s linear infinite;
            pointer-events: none;
        }
        @@keyframes ts-grid-move {
            from

        {
            background-position: 0 0;
        }

        to {
            background-position: 64px 64px;
        }

        }

        .ts-stat {
            border-radius: var(--ts-r);
            padding: 36px 24px;
            text-align: center;
            position: relative;
            overflow: hidden;
            border: 1px solid rgba(255,255,255,.08);
            background: rgba(255,255,255,.04);
            backdrop-filter: blur(12px);
            transition: all .3s;
        }

            .ts-stat:hover {
                transform: translateY(-8px);
                background: rgba(255,255,255,.07);
            }

        .ts-stat-orb {
            position: absolute;
            width: 160px;
            height: 160px;
            border-radius: 50%;
            top: -50px;
            right: -50px;
            filter: blur(60px);
            opacity: .35;
            pointer-events: none;
        }

        .ts-stat-blue .ts-stat-orb {
            background: var(--ts-blue);
        }

        .ts-stat-violet .ts-stat-orb {
            background: var(--ts-violet);
        }

        .ts-stat-emerald .ts-stat-orb {
            background: var(--ts-em);
        }

        .ts-stat-amber .ts-stat-orb {
            background: var(--ts-amb);
        }

        .ts-stat-iw {
            width: 60px;
            height: 60px;
            border-radius: 16px;
            margin: 0 auto 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 26px;
        }

        .ts-stat-iw-blue {
            background: rgba(59,130,246,.2);
            color: #93c5fd;
        }

        .ts-stat-iw-violet {
            background: rgba(124,58,237,.2);
            color: #c4b5fd;
        }

        .ts-stat-iw-emerald {
            background: rgba(16,185,129,.2);
            color: #6ee7b7;
        }

        .ts-stat-iw-amber {
            background: rgba(245,158,11,.2);
            color: #fcd34d;
        }

        .ts-stat-num {
            font-size: clamp(2.4rem,3.8vw,3.2rem);
            font-weight: 900;
            letter-spacing: -1.5px;
            margin-bottom: 8px;
            line-height: 1;
        }

        .ts-stat-num-blue {
            background: var(--ts-g-blue);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .ts-stat-num-violet {
            background: var(--ts-g-vio);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .ts-stat-num-emerald {
            background: var(--ts-g-em);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .ts-stat-num-amber {
            background: var(--ts-g-amb);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .ts-stat-label {
            font-size: 13px;
            color: #94a3b8;
            font-weight: 500;
            margin: 0;
        }

        /* ══════════════════════
           CTA
        ══════════════════════ */
        .ts-cta-card {
            background: var(--ts-g);
            border-radius: 28px;
            padding: 68px 60px;
            position: relative;
            overflow: hidden;
            box-shadow: 0 28px 80px rgba(79,70,229,.38),0 8px 28px rgba(79,70,229,.2);
        }

            .ts-cta-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: -100%;
                width: 60%;
                height: 100%;
                background: linear-gradient(90deg,transparent,rgba(255,255,255,.08),transparent);
                animation: ts-shimmer 4s ease-in-out infinite;
            }
        @@keyframes ts-shimmer {
            0%

        {
            left: -100%;
        }

        60%, 100% {
            left: 150%;
        }

        }

        .ts-cta-orb {
            position: absolute;
            border-radius: 50%;
            pointer-events: none;
        }

        .ts-cta-orb1 {
            width: 340px;
            height: 340px;
            top: -110px;
            right: -80px;
            background: rgba(255,255,255,.1);
        }

        .ts-cta-orb2 {
            width: 220px;
            height: 220px;
            bottom: -70px;
