@page
@model E_Commerce_Razor.Pages.Order.CheckoutModel
@{
    ViewData["Title"] = "Thanh toán";
}

<!-- Leaflet CSS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
      crossorigin="" />

<div class="container mt-4">
    <h2>@ViewData["Title"]</h2>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Thông tin giao hàng</h5>
                </div>
                <div class="card-body">
                    <form method="post" asp-page-handler="Create">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label asp-for="Input.ShippingAddress" class="form-label">Địa chỉ giao hàng <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input asp-for="Input.ShippingAddress" id="addressInput" class="form-control" placeholder="Số nhà, tên đường..." required />
                                <button type="button" class="btn btn-outline-primary" id="getCurrentLocationBtn">
                                    <i class="bi bi-geo-alt-fill"></i> Lấy vị trí hiện tại
                                </button>
                            </div>
                            <span asp-validation-for="Input.ShippingAddress" class="text-danger"></span>
                        </div>

                        <!-- Leaflet Map -->
                        <div class="mb-3">
                            <label class="form-label">Chọn vị trí trên bản đồ (tùy chọn)</label>
                            <div id="map" style="height: 400px; border-radius: 8px; border: 1px solid #ddd;"></div>
                            <small class="text-muted">Kéo marker hoặc click vào bản đồ để chọn vị trí chính xác</small>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Tỉnh/Thành phố <span class="text-danger">*</span></label>
                                <select id="province" class="form-select" required>
                                    <option value="">-- Chọn Tỉnh/TP --</option>
                                </select>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label">Phường/Xã <span class="text-danger">*</span></label>
                                <select id="ward" class="form-select" required disabled>
                                    <option value="">-- Chọn Phường/Xã --</option>
                                </select>
                            </div>
                        </div>

                        <!-- Hidden fields -->
                        <input asp-for="Input.City" type="hidden" id="cityHidden" />
                        <input asp-for="Input.Country" type="hidden" value="Vietnam" />

                        <div class="mb-3">
                            <label asp-for="Input.PostalCode" class="form-label">Mã bưu điện</label>
                            <input asp-for="Input.PostalCode" class="form-control" placeholder="700000" />
                            <span asp-validation-for="Input.PostalCode" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.PaymentMethod" class="form-label">Phương thức thanh toán <span class="text-danger">*</span></label>
                            <select asp-for="Input.PaymentMethod" class="form-select" required>
                                <option value="COD">Thanh toán khi nhận hàng (COD)</option>
                                <option value="VNPAY">💳 Thanh toán qua VNPAY</option>
                                <option value="BankTransfer">Chuyển khoản ngân hàng</option>
                                <option value="CreditCard">Thẻ tín dụng</option>
                            </select>
                            <span asp-validation-for="Input.PaymentMethod" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Note" class="form-label">Ghi chú</label>
                            <textarea asp-for="Input.Note" class="form-control" rows="3" placeholder="Ghi chú cho người giao hàng..."></textarea>
                            <span asp-validation-for="Input.Note" class="text-danger"></span>
                        </div>

                        <!-- ── MÃ GIẢM GIÁ / VOUCHER ── -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">🏷️ Mã giảm giá</label>

                            @if (Model.AvailableVouchers.Any())
                            {
                                <select class="form-select mb-2" id="availableVouchersSelect">
                                    <option value="">-- Chọn mã giảm giá khả dụng --</option>
                                    @foreach (var v in Model.AvailableVouchers)
                                    {
                                        var discountText = v.DiscountType == "Percent" ? $"{v.DiscountValue:0}%" : $"{v.DiscountValue:N0}đ";
                                        var maxDiscountText = v.MaxDiscount.HasValue ? $" (Tối đa {v.MaxDiscount.Value:N0}đ)" : "";
                                        <option value="@v.Code">
                                            [@v.Code] Giảm @discountText @maxDiscountText - @v.Description
                                        </option>
                                    }
                                </select>
                            }

                            <div class="input-group">
                                <input asp-for="Input.VoucherCode"
                                       id="voucherCodeInput"
                                       class="form-control text-uppercase"
                                       placeholder="Hoặc nhập mã giảm giá khác..."
                                       style="letter-spacing:1px;" />
                                <button type="button" class="btn btn-outline-primary" id="applyVoucherBtn">
                                    <i class="bi bi-tag-fill"></i> Áp dụng
                                </button>
                            </div>
                            <div id="voucherMessage" class="mt-2"></div>
                        </div>
                        <!-- ───────────────────────────── -->

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success btn-lg">
                                <i class="bi bi-check-circle"></i> Đặt hàng
                            </button>
                            <a href="/Shop" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Quay lại cửa hàng
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">Tóm tắt đơn hàng</h5>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <p class="mb-0"><i class="bi bi-info-circle"></i> Thông tin chi tiết sẽ được hiển thị sau khi bạn có sản phẩm trong giỏ hàng.</p>
                    </div>
                    <p class="text-muted small">
                        <i class="bi bi-shield-check"></i> Thông tin của bạn được bảo mật<br/>
                        <i class="bi bi-truck"></i> Giao hàng toàn quốc<br/>
                        <i class="bi bi-arrow-clockwise"></i> Đổi trả trong 7 ngày
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <!-- Leaflet JS -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
            integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
            crossorigin=""></script>

    <script>
        let map;
        let marker;
        let addressInput;
        let getCurrentLocationBtn;
        let provinceSelect;
        let wardSelect;
        let cityHidden;

        const API_BASE = 'https://esgoo.net/api-tinhthanh-new';

        // Gom tất cả init vào window.load (đảm bảo chạy đúng trong phần Scripts Razor Pages)
        window.addEventListener('load', function() {
            addressInput          = document.getElementById('addressInput');
            getCurrentLocationBtn = document.getElementById('getCurrentLocationBtn');
            provinceSelect        = document.getElementById('province');
            wardSelect            = document.getElementById('ward');
            cityHidden            = document.getElementById('cityHidden');

            // Khởi tạo Leaflet map - mặc định TP.HCM
            const defaultLat = 10.762622;
            const defaultLng = 106.660172;

            map = L.map('map').setView([defaultLat, defaultLng], 13);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
                maxZoom: 19
            }).addTo(map);

            marker = L.marker([defaultLat, defaultLng], { draggable: true }).addTo(map);

            // KHÔNG auto-geocode khi load → để user tự điền địa chỉ
            // Chỉ geocode khi user kéo marker hoặc click bản đồ
            marker.on('dragend', function(e) {
                reverseGeocode(e.target.getLatLng().lat, e.target.getLatLng().lng);
            });
            map.on('click', function(e) {
                marker.setLatLng(e.latlng);
                reverseGeocode(e.latlng.lat, e.latlng.lng);
            });

            // Load danh sách tỉnh/thành ngay khi trang sẵn sàng
            loadProvinces();

            // Sự kiện dropdown
            provinceSelect.addEventListener('change', onProvinceChange);
            wardSelect.addEventListener('change', updateCityField);

            // Nút lấy vị trí GPS
            getCurrentLocationBtn.addEventListener('click', function() {
                if (!navigator.geolocation) {
                    alert('Trình duyệt của bạn không hỗ trợ Geolocation');
                    return;
                }
                getCurrentLocationBtn.disabled = true;
                getCurrentLocationBtn.innerHTML = '<i class="bi bi-hourglass-split"></i> Đang lấy vị trí...';

                navigator.geolocation.getCurrentPosition(
                    function(position) {
                        const lat = position.coords.latitude;
                        const lng = position.coords.longitude;
                        map.setView([lat, lng], 15);
                        marker.setLatLng([lat, lng]);
                        reverseGeocode(lat, lng);
                        getCurrentLocationBtn.disabled = false;
                        getCurrentLocationBtn.innerHTML = '<i class="bi bi-geo-alt-fill"></i> Lấy vị trí hiện tại';
                    },
                    function(error) {
                        alert('Không thể lấy vị trí: ' + error.message);
                        getCurrentLocationBtn.disabled = false;
                        getCurrentLocationBtn.innerHTML = '<i class="bi bi-geo-alt-fill"></i> Lấy vị trí hiện tại';
                    },
                    { enableHighAccuracy: true, timeout: 10000, maximumAge: 0 }
                );
            });
        });

        // Reverse Geocoding (chỉ gọi khi user chủ động thao tác map/GPS)
        function reverseGeocode(lat, lng) {
            const url = `https://nominatim.openstreetmap.org/reverse?lat=${lat}&lon=${lng}&format=json&addressdetails=1`;
            fetch(url, { headers: { 'Accept-Language': 'vi' } })
                .then(r => r.json())
                .then(data => {
                    if (data && data.display_name) {
                        addressInput.value = data.display_name;
                        if (data.address) autoPopulateDropdowns(data.address);
                    }
                })
                .catch(err => console.error('Geocoding error:', err));
        }

        async function autoPopulateDropdowns(address) {
            try {
                const provinceName = address.province || address.city || address.state;
                const wardName = address.suburb || address.village || address.neighbourhood;
                if (provinceName) {
                    const provinceOption = Array.from(provinceSelect.options).find(opt =>
                        opt.textContent.includes(provinceName) || provinceName.includes(opt.dataset.name)
                    );
                    if (provinceOption) {
                        provinceSelect.value = provinceOption.value;
                        await onProvinceChange();
                        if (wardName) {
                            await new Promise(resolve => setTimeout(resolve, 1000));
                            const wardOption = Array.from(wardSelect.options).find(opt =>
                                opt.textContent.includes(wardName) || wardName.includes(opt.dataset.name)
                            );
                            if (wardOption) { wardSelect.value = wardOption.value; updateCityField(); }
                        }
                    }
                }
            } catch (err) { console.error('Error auto-populating dropdowns:', err); }
        }

        async function loadProvinces() {
            try {
                const response = await fetch(`${API_BASE}/4/0.htm`);
                const data = await response.json();
                if (data.error === 0) {
                    provinceSelect.innerHTML = '<option value="">-- Chọn Tỉnh/TP --</option>';
                    data.data.forEach(p => {
                        const opt = document.createElement('option');
                        opt.value = p.id;
                        opt.textContent = p.full_name;
                        opt.dataset.name = p.name;
                        provinceSelect.appendChild(opt);
                    });
                }
            } catch (e) { console.error('Error loading provinces:', e); }
        }

        async function onProvinceChange() {
            const provinceId = provinceSelect.value;
            wardSelect.innerHTML = '<option value="">-- Chọn Phường/Xã --</option>';
            wardSelect.disabled = true;
            if (!provinceId) return;
            try {
                const response = await fetch(`${API_BASE}/4/0.htm`);
                const data = await response.json();
                if (data.error === 0) {
                    const sel = data.data.find(p => p.id === provinceId);
                    if (sel && sel.data2) {
                        sel.data2.forEach(w => {
                            const opt = document.createElement('option');
                            opt.value = w.id;
                            opt.textContent = w.full_name;
                            opt.dataset.name = w.name;
                            wardSelect.appendChild(opt);
                        });
                        wardSelect.disabled = false;
                    }
                }
            } catch (e) { console.error('Error loading wards:', e); }
            updateCityField();
        }

        function updateCityField() {
            const pName = provinceSelect.options[provinceSelect.selectedIndex]?.dataset.name || '';
            const wName = wardSelect.options[wardSelect.selectedIndex]?.dataset.name || '';
            cityHidden.value = [wName, pName].filter(Boolean).join(', ');
        }

        // ── VOUCHER AJAX CHECK ─────────────────────────────────────────────
        document.getElementById('applyVoucherBtn')?.addEventListener('click', async function () {
            const code = document.getElementById('voucherCodeInput').value.trim();
            const msgBox = document.getElementById('voucherMessage');

            if (!code) {
                msgBox.innerHTML = '<div class="alert alert-warning py-1 mb-0">Vui lòng nhập mã giảm giá.</div>';
                return;
            }

            this.disabled = true;
            this.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Đang kiểm tra...';

            try {
                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                const resp  = await fetch('?handler=ValidateVoucher', {
                    method : 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                    body   : JSON.stringify(code)
                });
                const result = await resp.json();

                if (result.isSuccess) {
                    msgBox.innerHTML = `
                        <div class="alert alert-success py-2 mb-0">
                            ✅ <strong>${result.voucher.code}</strong>: ${result.voucher.description ?? 'Mã hợp lệ'}
                            <br>💰 Giảm: <strong class="text-danger">${result.discountAmount.toLocaleString('vi-VN')}đ</strong>
                            &nbsp;|&nbsp; 🧾 Còn lại: <strong>${result.finalAmount.toLocaleString('vi-VN')}đ</strong>
                        </div>`;
                } else {
                    msgBox.innerHTML = `<div class="alert alert-danger py-2 mb-0">❌ ${result.errorMessage}</div>`;
                }
            } catch (e) {
                msgBox.innerHTML = '<div class="alert alert-danger py-2 mb-0">Lỗi kết nối. Vui lòng thử lại.</div>';
            }

            this.disabled = false;
            this.innerHTML = '<i class="bi bi-tag-fill"></i> Áp dụng';
        });

        // Tự động điền code và check khi người dùng chọn từ dropdown
        document.getElementById('availableVouchersSelect')?.addEventListener('change', function() {
            const inputField = document.getElementById('voucherCodeInput');
            const msgBox = document.getElementById('voucherMessage');

            // Nếu người dùng chọn "-- Chọn mã --" (value rỗng)
            if (!this.value) {
                inputField.value = '';
                msgBox.innerHTML = '';
                return;
            }

            inputField.value = this.value;
            document.getElementById('applyVoucherBtn').click();
        });
    </script>
}
