@page "{id:int}"
@model E_Commerce_Razor.Pages.Order.DetailsModel
@{
    ViewData["Title"] = $"Chi tiết đơn hàng #{Model.Order?.OrderId}";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>@ViewData["Title"]</h2>
        <a asp-page="./Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model.Order != null)
    {
        <div class="row">
            <!-- Order Info -->
            <div class="col-md-8">
                <div class="card mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Thông tin đơn hàng</h5>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <p><strong>Mã đơn hàng:</strong> #@Model.Order.OrderId</p>
                                <p><strong>Ngày đặt:</strong> @Model.Order.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
                                <p><strong>Khách hàng:</strong> @Model.Order.FullName (@Model.Order.UserName)</p>
                            </div>
                            <div class="col-md-6">
                                <p><strong>Trạng thái:</strong>
                                    @if (Model.Order.Status == "Pending")
                                    {
                                        <span class="badge bg-warning text-dark"><i class="bi bi-clock-history"></i> Chờ xử lý</span>
                                    }
                                    else if (Model.Order.Status == "Hoàn thành")
                                    {
                                        <span class="badge bg-success"><i class="bi bi-patch-check-fill"></i> Hoàn thành</span>
                                    }
                                    else if (Model.Order.Status == "Paid")
                                    {
                                        <span class="badge bg-info"><i class="bi bi-credit-card"></i> Đã thanh toán</span>
                                    }
                                    else if (Model.Order.Status == "Shipped")
                                    {
                                        <span class="badge bg-primary"><i class="bi bi-truck"></i> Đang giao</span>
                                    }
                                    else if (Model.Order.Status == "Delivered")
                                    {
                                        <span class="badge bg-success"><i class="bi bi-check-circle"></i> Đã giao</span>
                                    }
                                    else if (Model.Order.Status == "Cancelled")
                                    {
                                        <span class="badge bg-danger"><i class="bi bi-x-circle"></i> Đã hủy</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@Model.Order.Status</span>
                                    }
                                </p>
                                <p><strong>Tổng tiền:</strong> <span class="text-danger fs-5">@Model.Order.TotalAmount.ToString("N0") ₫</span></p>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(Model.Order.Note))
                        {
                            <div class="alert alert-info">
                                <strong>Ghi chú:</strong> @Model.Order.Note
                            </div>
                        }

                        <!-- Order Items -->
                        <h6 class="mt-4 mb-3">Sản phẩm đã đặt</h6>
                        <div class="table-responsive">
                            <table class="table table-bordered">
                                <thead class="table-light">
                                    <tr>
                                        <th>Sản phẩm</th>
                                        <th class="text-center">Số lượng</th>
                                        <th class="text-end">Đơn giá</th>
                                        <th class="text-end">Thành tiền</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.Order.OrderItems)
                                    {
                                        <tr>
                                            <td>@item.ProductName</td>
                                            <td class="text-center">@item.Quantity</td>
                                            <td class="text-end">@item.UnitPrice.ToString("N0") ₫</td>
                                            <td class="text-end"><strong>@item.Subtotal.ToString("N0") ₫</strong></td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot>
                                    <tr class="table-active">
                                        <td colspan="3" class="text-end"><strong>Tổng cộng:</strong></td>
                                        <td class="text-end"><strong class="text-danger">@Model.Order.TotalAmount.ToString("N0") ₫</strong></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>

                        <!-- Cancel + Pay Buttons -->
                        @{
                            var canCancel = Model.Order.Status == "Pending"
                                || (Model.Order.Payment?.Status == "Paid"
                                    && (Model.Order.Shipping == null || !Model.Order.Shipping.ShippedDate.HasValue));
                        }
                        @if (canCancel)
                        {
                            <div class="d-flex gap-2 mt-3">
                                <form method="post" asp-page-handler="Cancel" asp-route-id="@Model.Order.OrderId"
                                      onsubmit="return confirm('Bạn có chắc muốn hủy đơn hàng này? Đối với đơn đã thanh toán, số tiền sẽ được hoàn lại theo chính sách của hệ thống.')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-danger">
                                        <i class="bi bi-x-circle"></i> Hủy đơn hàng
                                    </button>
                                </form>

                                @if (Model.Order.Payment == null || Model.Order.Payment.Status != "Paid")
                                {
                                    <form action="/Payment/Pay" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@Model.Order.OrderId" />
                                        <button type="submit" class="btn btn-success">
                                            <i class="bi bi-credit-card"></i> Thanh toán VNPAY
                                        </button>
                                    </form>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Shipping & Payment Info -->
            <div class="col-md-4">
                <!-- Tracking Timeline -->
                @if (Model.Order.Shipping != null)
                {
                    <div class="card mb-4">
                        <div class="card-header bg-success text-white">
                            <h6 class="mb-0"><i class="bi bi-geo-alt me-1"></i>Theo dõi đơn hàng</h6>
                        </div>
                        <div class="card-body p-3">
                            <!-- Timeline -->
                            <div class="position-relative ps-4" style="border-left: 2px solid #dee2e6;">

                                <!-- Bước 1: Đặt hàng -->
                                <div class="mb-3 position-relative">
                                    <div class="position-absolute" style="left:-21px; top:2px;">
                                        <span class="badge rounded-circle bg-success p-1"><i class="bi bi-check-lg" style="font-size:10px"></i></span>
                                    </div>
                                    <div class="fw-semibold small">Đặt hàng</div>
                                    <div class="text-muted" style="font-size:12px">@Model.Order.OrderDate.ToString("dd/MM/yyyy HH:mm")</div>
                                </div>

                                <!-- Bước 2: Thanh toán -->
                                <div class="mb-3 position-relative">
                                    <div class="position-absolute" style="left:-21px; top:2px;">
                                        @if (Model.Order.Status is "Paid" or "Shipped" or "Delivered")
                                        {
                                            <span class="badge rounded-circle bg-success p-1"><i class="bi bi-check-lg" style="font-size:10px"></i></span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-circle bg-secondary p-1"><i class="bi bi-circle" style="font-size:10px"></i></span>
                                        }
                                    </div>
                                    <div class="fw-semibold small">Đã thanh toán</div>
                                    <div class="text-muted" style="font-size:12px">
                                        @(Model.Order.Payment?.PaidAt?.ToString("dd/MM/yyyy HH:mm") ?? "Chờ thanh toán")
                                    </div>
                                </div>

                                <!-- Bước 3: Đang vận chuyển -->
                                <div class="mb-3 position-relative">
                                    <div class="position-absolute" style="left:-21px; top:2px;">
                                        @if (Model.Order.Status is "Shipped" or "Delivered")
                                        {
                                            <span class="badge rounded-circle bg-info p-1"><i class="bi bi-truck" style="font-size:10px"></i></span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-circle bg-secondary p-1"><i class="bi bi-circle" style="font-size:10px"></i></span>
                                        }
                                    </div>
                                    <div class="fw-semibold small">Đang vận chuyển</div>
                                    <div class="text-muted" style="font-size:12px">
                                        @(Model.Order.Shipping.ShippedDate?.ToString("dd/MM/yyyy HH:mm") ?? "Chờ lấy hàng")
                                    </div>
                                    @if (Model.Order.Shipping.ShipperName != null)
                                    {
                                        <div class="text-info small"><i class="bi bi-person me-1"></i>@Model.Order.Shipping.ShipperName</div>
                                    }
                                    @if (!string.IsNullOrEmpty(Model.Order.Shipping.Carrier))
                                    {
                                        <div class="text-muted small"><i class="bi bi-box me-1"></i>@Model.Order.Shipping.Carrier</div>
                                    }
                                    @if (!string.IsNullOrEmpty(Model.Order.Shipping.TrackingNumber))
                                    {
                                        <div class="small"><strong>Mã vận đơn:</strong> <span class="text-primary">@Model.Order.Shipping.TrackingNumber</span></div>
                                    }
                                </div>

                                <!-- Bước 4: Đã giao -->
                                <div class="position-relative">
                                    <div class="position-absolute" style="left:-21px; top:2px;">
                                        @if (Model.Order.Status == "Delivered")
                                        {
                                            <span class="badge rounded-circle bg-success p-1"><i class="bi bi-house-check" style="font-size:10px"></i></span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-circle bg-secondary p-1"><i class="bi bi-circle" style="font-size:10px"></i></span>
                                        }
                                    </div>
                                    <div class="fw-semibold small">Đã giao hàng</div>
                                    <div class="text-muted" style="font-size:12px">
                                        @(Model.Order.Shipping.DeliveryDate?.ToString("dd/MM/yyyy HH:mm") ?? "Chờ giao hàng")
                                    </div>
                                </div>
                            </div>

                            <!-- Địa chỉ giao -->
                            <hr/>
                            <div class="small">
                                <p class="mb-1"><strong><i class="bi bi-geo-alt me-1"></i>Địa chỉ:</strong></p>
                                <p class="text-muted mb-0">@Model.Order.Shipping.Address@(!string.IsNullOrEmpty(Model.Order.Shipping.City) ? ", " + Model.Order.Shipping.City : "")</p>
                            </div>
                        </div>
                    </div>
                }


                <!-- Payment Info -->
                @if (Model.Order.Payment != null)
                {
                    <div class="card">
                        <div class="card-header bg-info text-white">
                            <h6 class="mb-0">Thông tin thanh toán</h6>
                        </div>
                        <div class="card-body">
                            <p><strong>Phương thức:</strong> @Model.Order.Payment.PaymentMethod</p>
                            <p><strong>Số tiền:</strong> @Model.Order.Payment.Amount.ToString("N0") ₫</p>
                            <p><strong>Trạng thái:</strong>
                                @if (Model.Order.Payment.Status == "Paid")
                                {
                                    <span class="badge bg-success">Đã thanh toán</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Chưa thanh toán</span>
                                }
                            </p>
                            @if (Model.Order.Payment.PaidAt.HasValue)
                            {
                                <p><strong>Ngày thanh toán:</strong> @Model.Order.Payment.PaidAt.Value.ToString("dd/MM/yyyy HH:mm")</p>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>
