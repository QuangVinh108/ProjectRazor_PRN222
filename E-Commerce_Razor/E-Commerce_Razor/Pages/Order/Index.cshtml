@page
@model E_Commerce_Razor.Pages.Order.IndexModel
@{
    ViewData["Title"] = "Đơn hàng của tôi";
}

<!-- Modern Order History Page -->
<div class="container py-5">
    <!-- Header Section -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <h1 class="fw-bold mb-2">
                        <i class="bi bi-bag-check text-primary me-2"></i>
                        @ViewData["Title"]
                    </h1>
                    <p class="text-muted mb-0">Quản lý và theo dõi đơn hàng của bạn</p>
                </div>
                @if (Model.Orders != null && Model.Orders.Any())
                {
                    <div class="badge bg-primary fs-6 px-3 py-2">
                        @Model.Orders.Count đơn hàng
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Alert Messages -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm border-0" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Empty State -->
    @if (Model.Orders == null || !Model.Orders.Any())
    {
        <div class="empty-state text-center py-5">
            <div class="empty-state-icon mb-4">
                <i class="bi bi-cart-x display-1 text-muted"></i>
            </div>
            <h3 class="mb-3">Chưa có đơn hàng nào</h3>
            <p class="text-muted mb-4">Bạn chưa thực hiện đơn hàng nào. Hãy khám phá sản phẩm và mua sắm ngay!</p>
            <a href="/Shop" class="btn btn-primary btn-lg">
                <i class="bi bi-shop me-2"></i>
                Mua sắm ngay
            </a>
        </div>
    }
    else
    {
        <!-- Desktop View (Table) -->
        <div class="d-none d-lg-block">
            <div class="card border-0 shadow-sm">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 modern-order-table">
                        <thead class="bg-light">
                            <tr>
                                <th class="border-0 px-4 py-3">Mã đơn hàng</th>
                                <th class="border-0 py-3">Ngày đặt</th>
                                <th class="border-0 py-3">Trạng thái</th>
                                <th class="border-0 py-3">Tổng tiền</th>
                                <th class="border-0 py-3 text-end pe-4">Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model.Orders)
                            {
                                <tr class="order-row">
                                    <td class="px-4">
                                        <strong class="text-primary">#@order.OrderId</strong>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <i class="bi bi-calendar3 text-muted"></i>
                                            <span>@order.OrderDate.ToString("dd/MM/yyyy")</span>
                                        </div>
                                        <small class="text-muted">@order.OrderDate.ToString("HH:mm")</small>
                                    </td>
                                    <td>
                                        @if (order.Status == "Pending")
                                        {
                                            <span class="status-badge status-pending"><i class="bi bi-clock-history"></i> Chờ xử lý</span>
                                        }
                                        else if (order.Status == "Hoàn thành")
                                        {
                                            <span class="status-badge status-delivered"><i class="bi bi-patch-check-fill"></i> Hoàn thành</span>
                                        }
                                        else if (order.Status == "Paid")
                                        {
                                            <span class="status-badge status-paid"><i class="bi bi-credit-card"></i> Đã thanh toán</span>
                                        }
                                        else if (order.Status == "Shipped")
                                        {
                                            <span class="status-badge status-shipped"><i class="bi bi-truck"></i> Đang giao</span>
                                        }
                                        else if (order.Status == "Delivered")
                                        {
                                            <span class="status-badge status-delivered"><i class="bi bi-check-circle"></i> Đã giao</span>
                                        }
                                        else if (order.Status == "Cancelled")
                                        {
                                            <span class="status-badge status-cancelled"><i class="bi bi-x-circle"></i> Đã hủy</span>
                                        }
                                        else
                                        {
                                            <span class="status-badge status-default">@order.Status</span>
                                        }
                                    </td>
                                    <td>
                                        <strong class="text-danger fs-5">@order.TotalAmount.ToString("N0") ₫</strong>
                                    </td>
                                    <td class="text-end pe-4">
                                        <a asp-page="./Details" asp-route-id="@order.OrderId"
                                           class="btn btn-primary btn-sm">
                                            <i class="bi bi-eye me-1"></i> Xem chi tiết
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Mobile View (Cards) -->
        <div class="d-lg-none">
            @foreach (var order in Model.Orders)
            {
                <div class="card order-card mb-3 border-0 shadow-sm">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <h5 class="mb-1">
                                    <strong class="text-primary">#@order.OrderId</strong>
                                </h5>
                                <small class="text-muted">
                                    <i class="bi bi-calendar3 me-1"></i>
                                    @order.OrderDate.ToString("dd/MM/yyyy HH:mm")
                                </small>
                            </div>
                            <div>
                                @if (order.Status == "Pending")
                                {
                                    <span class="status-badge status-pending"><i class="bi bi-clock-history"></i> Chờ xử lý</span>
                                }
                                else if (order.Status == "Hoàn thành")
                                {
                                    <span class="status-badge status-delivered"><i class="bi bi-patch-check-fill"></i> Hoàn thành</span>
                                }
                                else if (order.Status == "Paid")
                                {
                                    <span class="status-badge status-paid"><i class="bi bi-credit-card"></i> Đã thanh toán</span>
                                }
                                else if (order.Status == "Shipped")
                                {
                                    <span class="status-badge status-shipped"><i class="bi bi-truck"></i> Đang giao</span>
                                }
                                else if (order.Status == "Delivered")
                                {
                                    <span class="status-badge status-delivered"><i class="bi bi-check-circle"></i> Đã giao</span>
                                }
                                else if (order.Status == "Cancelled")
                                {
                                    <span class="status-badge status-cancelled"><i class="bi bi-x-circle"></i> Đã hủy</span>
                                }
                                else
                                {
                                    <span class="status-badge status-default">@order.Status</span>
                                }
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center pt-3 border-top">
                            <div>
                                <small class="text-muted d-block mb-1">Tổng tiền</small>
                                <strong class="text-danger fs-4">@order.TotalAmount.ToString("N0") ₫</strong>
                            </div>
                            <a asp-page="./Details" asp-route-id="@order.OrderId"
                               class="btn btn-primary">
                                <i class="bi bi-eye me-1"></i> Chi tiết
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.82rem;
        font-weight: 600;
    }

    .status-pending  { background: #fff3cd; color: #856404; }
    .status-paid     { background: #cff4fc; color: #055160; }
    .status-shipped  { background: #cfe2ff; color: #084298; }
    .status-delivered { background: #d1e7dd; color: #0a3622; }
    .status-cancelled { background: #f8d7da; color: #842029; }
    .status-default  { background: #e9ecef; color: #495057; }

    .order-row:hover { background-color: #f8f9ff; }
    .order-card { transition: all 0.2s ease; }
    .order-card:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(0,0,0,0.08) !important; }
</style>
