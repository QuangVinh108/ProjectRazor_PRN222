    <div class="position-fixed bottom-0 end-0 p-3" style="z-index: 1050">
        <div class="card shadow-lg border-0 d-none" id="chatBox" style="width: 340px; height: 500px; border-radius: 12px 12px 0 0; overflow: hidden; display: flex; flex-direction: column;">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center flex-shrink-0" style="border-radius: 12px 12px 0 0;">
                <h6 class="mb-0 fw-bold"><i class="bi bi-chat-dots-fill me-2"></i> Hỗ trợ trực tuyến</h6>
                <button type="button" class="btn-close btn-close-white" onclick="toggleChat()"></button>
            </div>

            <div class="card-body p-2" id="chatMessages" style="flex-grow: 1; overflow-y: auto; background: #f8f9fa;">
                <div class="text-center text-muted small my-2">Bắt đầu cuộc trò chuyện</div>
            </div>

            <div id="emojiPickerContainer" class="d-none border-top flex-shrink-0" style="height: 250px; background: #fff;"></div>

            <div class="card-footer p-2 bg-white border-0 flex-shrink-0">
                <div class="input-group bg-light rounded-pill border p-1 d-flex align-items-center">
                    <button class="btn btn-sm btn-link text-secondary rounded-circle px-2" onclick="document.getElementById('chatFileInput').click()" title="Đính kèm ảnh/file">
                        <i class="bi bi-paperclip fs-5"></i>
                    </button>
                    <input type="file" id="chatFileInput" class="d-none" accept="image/*, .pdf, .doc, .docx, .xls, .xlsx, .txt, .zip, .rar" onchange="handleChatFileUpload(event)">

                    <input type="text" id="chatInput" class="form-control border-0 bg-transparent shadow-none" placeholder="Nhập tin nhắn..." onkeypress="handleEnterChat(event)">

                    <button class="btn btn-sm btn-link text-warning rounded-circle px-2" id="emojiButton" title="Biểu tượng cảm xúc">
                        <i class="bi bi-emoji-smile fs-5"></i>
                    </button>

                    <button class="btn btn-primary btn-sm rounded-pill px-3 ms-1" onclick="sendChatMessage()">
                        <i class="bi bi-send-fill"></i>
                    </button>
                </div>
            </div>
        </div>

        <button class="btn btn-primary rounded-circle shadow-lg mt-2 float-end d-flex align-items-center justify-content-center"
                id="btnOpenChat" onclick="toggleChat()"
                style="width: 60px; height: 60px; transition: transform 0.2s;">
            <i class="bi bi-chat-dots-fill fs-3"></i>
        </button>
    </div>

    <div class="position-fixed top-0 end-0 p-3" style="z-index: 9999">
        <div id="wishlistToast" class="toast align-items-center text-white bg-danger border-0 shadow-lg" role="alert">
            <div class="d-flex">
                <div class="toast-body fw-bold">
                    <i class="bi bi-heart-fill me-2"></i> Đã cập nhật Wishlist!
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.12/signalr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/picmo@5.7.6/dist/umd/index.js"></script>

    <script>
        (function () {
          function initDropdownsFixed() {
            if (typeof bootstrap === 'undefined' || !bootstrap.Dropdown) return;
            document.querySelectorAll('[data-bs-toggle="dropdown"]').forEach(function (el) {
              var inst = bootstrap.Dropdown.getInstance(el);
              if (inst) inst.dispose();
              new bootstrap.Dropdown(el, {
                popperConfig: function (defaultConfig) {
                  return Object.assign({}, defaultConfig, { strategy: 'fixed' });
                }
              });
            });
          }
          if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initDropdownsFixed);
          } else {
            initDropdownsFixed();
          }
        })();
    </script>

    <script>
        const isAuthenticatedUser = @Json.Serialize(User?.Identity?.IsAuthenticated ?? false);
    </script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const wishlistLink = document.getElementById("wishlistLink");
            if (!wishlistLink) return;

            wishlistLink.addEventListener("click", function (e) {
                if (isAuthenticatedUser) return;
                e.preventDefault();
                document.getElementById('loginRequiredModalLabel').innerHTML = '<i class="bi bi-heart-fill text-danger"></i> Yêu cầu đăng nhập';
                document.getElementById('loginModalTitleText').innerText = 'Bạn cần đăng nhập để sử dụng Wishlist';
                bootstrap.Modal.getOrCreateInstance(document.getElementById("loginRequiredModal")).show();
            });
        });

        $(document).ready(function() {
            if (isAuthenticatedUser) {
                updateWishlistCount();
                setInterval(updateWishlistCount, 30000);
            }
        });

        async function updateWishlistCount() {
            try {
                // Razor Pages endpoint for Count handler
                const response = await fetch('/Wishlist?handler=Count');
                if (!response.ok) return;

                const data = await response.json();
                const count = typeof data === 'number' ? data : (data?.count ?? 0);

                const badge = document.getElementById('wishlistBadge');
                if (badge) {
                    badge.textContent = count;
                    badge.style.display = count > 0 ? 'block' : 'none';
                }
            } catch (e) { console.log('Failed to load wishlist count:', e); }
        }
    </script>

    <script>
        let chatConnection = null;

        if (isAuthenticatedUser) {
            chatConnection = new signalR.HubConnectionBuilder().withUrl("/appHub").build();

            chatConnection.on("ReceiveMessage", function (user, message) {
                const msgDiv = document.getElementById("chatMessages");
                const isMyMsg = (user === "Bạn");
                const alignClass = isMyMsg ? "text-end" : "text-start";
                const bgClass = isMyMsg ? "bg-primary text-white" : "bg-white border border-success border-2 shadow-sm";

                const msgHtml = `
                    <div class="mb-2 ${alignClass}">
                        <small class="d-block text-muted mb-1" style="font-size: 10px; font-weight: ${!isMyMsg ? 'bold' : 'normal'}">${user}</small>
                        <div class="d-inline-block p-2 rounded-3 shadow-sm ${bgClass}" style="max-width: 85%; text-align: left; word-break: break-word; font-size: 0.9rem;">
                            ${message}
                        </div>
                    </div>
                `;

                msgDiv.insertAdjacentHTML('beforeend', msgHtml);
                msgDiv.scrollTop = msgDiv.scrollHeight;
            });

            chatConnection.start().catch(err => console.error("SignalR Chat Error: ", err.toString()));

            // KHỞI TẠO BẢNG EMOJI INLINE
            document.addEventListener('DOMContentLoaded', () => {
                const emojiButton = document.getElementById('emojiButton');
                const chatInput = document.getElementById('chatInput');
                const emojiPickerContainer = document.getElementById('emojiPickerContainer');
                const chatMessages = document.getElementById('chatMessages');

                let picker = null;

                if (emojiButton && typeof picmo !== 'undefined') {
                    emojiButton.addEventListener('click', (e) => {
                        e.preventDefault();
                        e.stopPropagation();

                        emojiPickerContainer.classList.toggle('d-none');

                        if (!picker && !emojiPickerContainer.classList.contains('d-none')) {
                            picker = picmo.createPicker({
                                rootElement: emojiPickerContainer,
                                showSearch: false,
                                visibleRows: 4
                            });

                            picker.addEventListener('emoji:select', selection => {
                                chatInput.value += selection.emoji;
                                chatInput.focus();
                            });
                        }

                        chatMessages.scrollTop = chatMessages.scrollHeight;
                    });
                }
            });
        }

        function sendChatMessage() {
            if (!isAuthenticatedUser) return;
            const input = document.getElementById("chatInput");
            const message = input.value.trim();
            if (message && chatConnection) {
                chatConnection.invoke("SendMessageToSupport", message).catch(err => console.error(err.toString()));
                input.value = "";

                const emojiContainer = document.getElementById('emojiPickerContainer');
                if(emojiContainer && !emojiContainer.classList.contains('d-none')) {
                    emojiContainer.classList.add('d-none');
                }
            }
        }

        function handleEnterChat(e) {
            if (e.key === 'Enter') sendChatMessage();
        }

        function toggleChat() {
            if (!isAuthenticatedUser) {
                document.getElementById('loginRequiredModalLabel').innerHTML = '<i class="bi bi-chat-dots-fill text-primary"></i> Hỗ trợ trực tuyến';
                document.getElementById('loginModalTitleText').innerText = 'Vui lòng đăng nhập để Chat với CSKH';
                bootstrap.Modal.getOrCreateInstance(document.getElementById("loginRequiredModal")).show();
                return;
            }
            const box = document.getElementById('chatBox');
            const btn = document.getElementById('btnOpenChat');
            box.classList.toggle('d-none');
            btn.classList.toggle('d-none');

            if (!box.classList.contains('d-none')) {
                setTimeout(() => document.getElementById('chatInput').focus(), 100);
            }
        }

        function handleChatFileUpload(event) {
            if (!isAuthenticatedUser || !chatConnection) return;

            const file = event.target.files[0];
            if (!file) return;

            if (file.size > 5 * 1024 * 1024) {
                alert("Kích thước file quá lớn. Vui lòng chọn file dưới 5MB.");
                event.target.value = '';
                return;
            }

            const reader = new FileReader();
            reader.onload = function(e) {
                const base64Data = e.target.result;
                let htmlMessage = "";

                if (file.type.startsWith("image/")) {
                    htmlMessage = `<img src="${base64Data}" style="max-width: 100%; border-radius: 8px; cursor: pointer; max-height: 150px; object-fit: contain;" onclick="window.open(this.src, '_blank')" alt="Hình ảnh" />`;
                } else {
                    htmlMessage = `
                        <a href="${base64Data}" download="${file.name}" class="d-inline-flex align-items-center text-decoration-none text-dark bg-white border p-2 rounded shadow-sm">
                            <i class="bi bi-file-earmark-arrow-down-fill text-primary fs-4 me-2"></i>
                            <div class="text-truncate" style="max-width: 150px; font-size: 0.85rem;">
                                <strong class="d-block text-truncate">${file.name}</strong>
                                <span class="text-muted small">${(file.size / 1024).toFixed(1)} KB</span>
                            </div>
                        </a>`;
                }

                chatConnection.invoke("SendMessageToSupport", htmlMessage).catch(err => console.error(err.toString()));
            };

            reader.readAsDataURL(file);
            event.target.value = '';
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>