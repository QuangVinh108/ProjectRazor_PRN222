@page "{id:int}"
@model E_Commerce_Razor.Pages.Shop.DetailsModel
@{
    ViewData["Title"] = Model.ProductDetail.ProductName;
}

<div class="container pt-4">
    <button id="smartBackBtn" onclick="smartBack()" class="btn btn-outline-secondary btn-back">
        <i id="backButtonIcon" class="bi bi-arrow-left"></i>
        <span id="backButtonText">Quay lại</span>
    </button>
</div>

<div class="container py-5">
    <div class="row gx-5">
        <div class="col-lg-6 mb-4">
            <div class="border rounded-4 p-3 bg-light text-center d-flex align-items-center justify-content-center" style="min-height: 400px; position: relative;" id="image-container">
                @if (!string.IsNullOrEmpty(Model.ProductDetail.Image))
                {
                    <img id="detail-image" src="@Model.ProductDetail.Image" class="img-fluid rounded shadow-sm" style="max-height: 500px; object-fit: contain; transition: all 0.3s ease;" alt="@Model.ProductDetail.ProductName">
                }
                else
                {
                    <img id="detail-image" src="https://placehold.co/600x600?text=No+Image" class="img-fluid rounded opacity-50" style="transition: all 0.3s ease;" alt="@Model.ProductDetail.ProductName">
                }
            </div>
        </div>

        <div class="col-lg-6">
            <div class="ps-lg-3" id="info-container" style="transition: all 0.3s ease; padding: 15px; border-radius: 10px;">
                <h4 id="detail-category" class="text-muted text-uppercase mb-2">@Model.ProductDetail.CategoryName</h4>
                <h1 id="detail-name" class="fw-bold mb-3">@Model.ProductDetail.ProductName</h1>

                <div class="mb-3">
                    <span id="detail-price" class="fs-2 fw-bold text-danger me-2">@Model.ProductDetail.Price.ToString("N0") ₫</span>

                    <span id="detail-sku" class="badge bg-secondary" style="display: @(string.IsNullOrEmpty(Model.ProductDetail.Sku) ? "none" : "inline-block")">
                        SKU: @Model.ProductDetail.Sku
                    </span>
                </div>

                <p id="detail-desc" class="lead mb-4 text-secondary" style="font-size: 1rem; white-space: pre-line;">
                    @(Model.ProductDetail.Description ?? "Sản phẩm này chưa có mô tả chi tiết.")
                </p>

                <form action="/Cart/Add" method="post" class="d-flex gap-3 align-items-center mb-4 add-to-cart-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@Model.ProductDetail.ProductId" />
                    <input type="number" name="quantity" class="form-control quantity-input" value="1" min="1" style="width: 80px;" />
                    <button type="submit" class="btn btn-primary btn-lg flex-grow-1">
                        <i class="bi bi-cart-plus me-2"></i> Thêm vào giỏ hàng
                    </button>
                    <button type="button"
                            class="btn btn-outline-danger btn-lg wishlist-toggle-detail"
                            data-product-id="@Model.ProductDetail.ProductId"
                            title="Thêm vào yêu thích">
                        <i class="bi bi-heart text-secondary wishlist-icon"></i>
                    </button>
                </form>

                <form action="/Order/BuyNow" method="post" class="mt-3 buy-now-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@Model.ProductDetail.ProductId" />
                    <input type="hidden" name="quantity" class="buy-now-quantity" value="1" />

                    <button type="submit" class="btn btn-danger btn-lg w-100">
                        <i class="bi bi-lightning-fill me-1"></i> Mua ngay
                    </button>
                </form>

                <div class="border-top pt-4 mt-4">
                    <div class="d-flex align-items-center mb-2">
                        <i class="bi bi-truck text-success fs-4 me-3"></i>
                        <span>Miễn phí vận chuyển cho đơn hàng trên 500k</span>
                    </div>
                    <div class="d-flex align-items-center">
                        <i class="bi bi-shield-check text-primary fs-4 me-3"></i>
                        <span>Bảo hành chính hãng 12 tháng</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.12/signalr.min.js"></script>
    <script>
        // ----------------------------------------------------
        // 1. CÁC HÀM TIỆN ÍCH
        // ----------------------------------------------------
        function smartBack() {
            const referrer = document.referrer;
            const currentHost = window.location.hostname;
            if (referrer && referrer.includes(currentHost)) {
                if (referrer.toLowerCase().includes('/wishlist')) {
                    window.location.href = '/Wishlist/Index';
                    return;
                }
                if (referrer.toLowerCase().includes('/shop')) {
                    window.location.href = '/Shop/Index';
                    return;
                }
                window.history.back();
            } else {
                window.location.href = '/';
            }
        }

        function updateBackButton() {
            const backBtn = document.getElementById('smartBackBtn');
            const backText = document.getElementById('backButtonText');
            const backIcon = document.getElementById('backButtonIcon');
            if (!backBtn) return;
            const referrer = document.referrer;
            if (referrer) {
                if (referrer.toLowerCase().includes('/wishlist')) {
                    backText.textContent = 'Quay lại Wishlist';
                    backIcon.className = 'bi bi-heart-fill';
                    backBtn.classList.remove('btn-outline-secondary');
                    backBtn.classList.add('btn-outline-danger');
                } else if (referrer.toLowerCase().includes('/shop')) {
                    backText.textContent = 'Quay lại Sản phẩm';
                    backIcon.className = 'bi bi-shop';
                    backBtn.classList.remove('btn-outline-secondary');
                    backBtn.classList.add('btn-outline-primary');
                }
            }
        }

        // HÀM MỞ MODAL ĐĂNG NHẬP
        function showLoginModal() {
            const returnUrl = encodeURIComponent(window.location.pathname + window.location.search);
            const loginBtn = document.getElementById("goLoginBtn");
            if(loginBtn) loginBtn.href = `/Account/Login?ReturnUrl=${returnUrl}`;

            const modalEl = document.getElementById('loginRequiredModal');
            if(modalEl) {
                bootstrap.Modal.getOrCreateInstance(modalEl).show();
            } else {
                window.location.href = `/Account/Login?ReturnUrl=${returnUrl}`;
            }
        }

        // HÀM ADD TO CART
        (function () {
            const form = document.querySelector('.add-to-cart-form');
            if (!form) return;
            form.addEventListener('submit', async function (e) {
                e.preventDefault();
                const fd = new FormData(form);
                const submitBtn = form.querySelector('button[type="submit"]');
                const originalHTML = submitBtn.innerHTML;
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Đang xử lý...';
                try {
                    const token = fd.get('__RequestVerificationToken');
                    const res = await fetch(form.action, {
                        method: 'POST',
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest',
                            'RequestVerificationToken': token
                        },
                        credentials: 'same-origin',
                        body: fd
                    });

                    if (res.status === 401 || res.status === 403 || res.url.includes('Login')) {
                        showLoginModal();
                        submitBtn.innerHTML = originalHTML;
                        submitBtn.disabled = false;
                        return;
                    }

                    if (res.ok) {
                        try {
                            const data = await res.json();
                            if (data.success === false) throw new Error();
                            const badge = document.getElementById('cartBadge');
                            if (badge && data.count !== undefined) {
                                badge.textContent = data.count;
                                badge.style.display = data.count > 0 ? 'block' : 'none';
                            }
                        } catch(e) { }

                        submitBtn.innerHTML = '<i class="bi bi-check-lg me-2"></i>Đã thêm';
                        submitBtn.classList.remove('btn-primary');
                        submitBtn.classList.add('btn-success');

                        const toastEl = document.getElementById('cartToast');
                        if (toastEl) new bootstrap.Toast(toastEl).show();
                        else alert('Đã thêm vào giỏ hàng!');

                        setTimeout(() => {
                            submitBtn.innerHTML = originalHTML;
                            submitBtn.classList.remove('btn-success');
                            submitBtn.classList.add('btn-primary');
                            submitBtn.disabled = false;
                        }, 1500);
                    } else {
                        throw new Error();
                    }
                } catch (err) {
                    alert('Lỗi kết nối hoặc xử lý giỏ hàng!');
                    submitBtn.innerHTML = originalHTML;
                    submitBtn.disabled = false;
                }
            });
        })();

        // HÀM BUY NOW
        (function() {
            const buyNowForm = document.querySelector('.buy-now-form');
            if (!buyNowForm) return;
            buyNowForm.addEventListener('submit', async function(e) {
                e.preventDefault();
                const quantityInput = document.querySelector('.quantity-input');
                const buyNowQuantity = buyNowForm.querySelector('.buy-now-quantity');
                if (quantityInput && buyNowQuantity) buyNowQuantity.value = quantityInput.value;
                const fd = new FormData(buyNowForm);
                const submitBtn = buyNowForm.querySelector('button[type="submit"]');
                const originalHTML = submitBtn.innerHTML;
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Đang xử lý...';
                try {
                    const token = fd.get('__RequestVerificationToken');
                    const res = await fetch(buyNowForm.action, {
                        method: 'POST',
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest',
                            'RequestVerificationToken': token
                        },
                        credentials: 'same-origin',
                        body: fd
                    });

                    if (res.status === 401 || res.status === 403 || res.url.includes('Login')) {
                        showLoginModal();
                        submitBtn.innerHTML = originalHTML;
                        submitBtn.disabled = false;
                        return;
                    }

                    if (res.ok) {
                        try {
                            const data = await res.json();
                            if (data.redirectUrl) {
                                window.location.href = data.redirectUrl;
                                return;
                            }
                        } catch(e) {}
                        window.location.href = '/Order/Checkout';
                    }
                } catch (err) {
                    alert('Lỗi kết nối!');
                    submitBtn.innerHTML = originalHTML;
                    submitBtn.disabled = false;
                }
            });
        })();

        // ----------------------------------------------------
        // HÀM WISHLIST
        // ----------------------------------------------------
        $(function() {
            const wishlistBtn = $('.wishlist-toggle-detail');
            if (!wishlistBtn.length) return;

            // KIỂM TRA LÚC TẢI TRANG
            (async function checkWishlistStatus() {
                const productId = wishlistBtn.data('product-id');
                try {
                    const res = await fetch(`/Wishlist?handler=Check&productId=${productId}`);
                    const data = await res.json();
                    const icon = wishlistBtn.find('.wishlist-icon');
                    if (data.isInWishlist) {
                        icon.removeClass('bi-heart text-secondary').addClass('bi-heart-fill');
                        wishlistBtn.removeClass('btn-outline-danger').addClass('btn-danger');
                        wishlistBtn.attr('title', 'Xóa khỏi yêu thích');
                    }
                } catch(e) { console.log('Check wishlist fail:', e); }
            })();

            // XỬ LÝ LÚC BẤM NÚT
            wishlistBtn.on('click', async function (e) {
                e.preventDefault();
                const btn = $(this);
                const icon = btn.find('.wishlist-icon');
                const productId = btn.data('product-id');
                const originalHTML = btn.html();

                btn.prop('disabled', true);
                btn.html('<span class="spinner-border spinner-border-sm"></span>');

                try {
                    const token = $('input[name="__RequestVerificationToken"]').first().val();
                    const res = await fetch(`/Wishlist?handler=Toggle&productId=${productId}`, {
                        method: 'POST',
                        headers: {
                            'RequestVerificationToken': token,
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });

                    if (res.status === 401 || res.url.includes('Login')) {
                        showLoginModal();
                        btn.html(originalHTML);
                        btn.prop('disabled', false);
                        return;
                    }

                    if (res.ok) {
                        btn.html(originalHTML);
                        const newIcon = btn.find('.wishlist-icon');

                        try {
                            const data = await res.json();

                            if (data.isAdded === true) {
                                newIcon.removeClass('bi-heart text-secondary').addClass('bi-heart-fill');
                                btn.removeClass('btn-outline-danger').addClass('btn-danger');
                                btn.attr('title', 'Xóa khỏi yêu thích');
                            } else {
                                newIcon.removeClass('bi-heart-fill').addClass('bi-heart text-secondary');
                                btn.removeClass('btn-danger').addClass('btn-outline-danger');
                                btn.attr('title', 'Thêm vào yêu thích');
                            }

                            if (typeof data.count === 'number') {
                                const badge = document.getElementById('wishlistBadge');
                                if (badge) {
                                    badge.textContent = data.count;
                                    badge.style.display = data.count > 0 ? 'block' : 'none';
                                }
                            }
                        } catch(e) {}

                        // Hiện Toast
                        const toastEl = document.getElementById('wishlistToast');
                        if (toastEl) new bootstrap.Toast(toastEl).show();
                    } else {
                        throw new Error();
                    }
                } catch (err) {
                    console.error('Wishlist error:', err);
                    btn.html(originalHTML);
                } finally {
                    btn.prop('disabled', false);
                }
            });
        });

        document.addEventListener('DOMContentLoaded', function() {
            updateBackButton();
        });

        // ----------------------------------------------------
        // 2. SIGNALR: LẮNG NGHE CẬP NHẬT TỪ ADMIN
        // ----------------------------------------------------
        const currentProductId = @Model.ProductDetail.ProductId;
        const detailConnection = new signalR.HubConnectionBuilder()
            .withUrl("/appHub")
            .build();

        detailConnection.on("ReceiveProductUpdate", function (product) {
            if (String(product.productId) === String(currentProductId)) {
                if (product.status === 0) {
                    // Hiển thị thông báo thân thiện hơn thay vì alert
                    showProductUnavailableNotification();
                    return;
                }
                document.getElementById('detail-name').innerText = product.productName;
                document.getElementById('detail-category').innerText = product.categoryName;
                document.getElementById('detail-price').innerText = Number(product.price).toLocaleString('vi-VN') + ' ₫';

                const skuEl = document.getElementById('detail-sku');
                if (skuEl) {
                    if (product.sku) {
                        skuEl.innerText = "SKU: " + product.sku;
                        skuEl.style.display = "inline-block";
                    } else {
                        skuEl.style.display = "none";
                    }
                }
                const descEl = document.getElementById('detail-desc');
                if (descEl) {
                    descEl.innerText = product.description ? product.description : "Sản phẩm này chưa có mô tả chi tiết.";
                }
                const imgEl = document.getElementById('detail-image');
                if (imgEl && imgEl.src !== window.location.origin + product.image) {
                    imgEl.src = product.image;
                }
                const infoBox = document.getElementById('info-container');
                if (infoBox) {
                    infoBox.style.boxShadow = "0 0 20px rgba(25, 135, 84, 0.5)";
                    infoBox.style.backgroundColor = "rgba(25, 135, 84, 0.05)";
                    setTimeout(() => {
                        infoBox.style.boxShadow = "none";
                        infoBox.style.backgroundColor = "transparent";
                    }, 1500);
                }
            }
        });

        detailConnection.on("ReceiveProductDelete", function (deletedProductId) {
            if (String(deletedProductId) === String(currentProductId)) {
                // Hiển thị thông báo thân thiện hơn thay vì alert
                showProductUnavailableNotification();
            }
        });

        // Hàm hiển thị thông báo sản phẩm không còn nữa
        function showProductUnavailableNotification() {
            // Thay đổi nội dung html của phần hiển thị sản phẩm
            const infoContainer = document.getElementById('info-container');
            const imageContainer = document.getElementById('image-container');

            if(imageContainer) {
                imageContainer.style.opacity = '0.5';
            }

            if(infoContainer) {
                 infoContainer.innerHTML = `
                    <div class="alert alert-warning" role="alert">
                      <h4 class="alert-heading"><i class="bi bi-exclamation-triangle-fill me-2"></i>Sản phẩm không khả dụng!</h4>
                      <p>Sản phẩm này vừa ngừng kinh doanh hoặc tạm ẩn bởi quản trị viên.</p>
                      <hr>
                      <p class="mb-0">Bạn sẽ được chuyển hướng về trang Cửa hàng trong vài giây.</p>
                    </div>
                `;
            }

            // Chuyển hướng sau 3 giây
            setTimeout(() => {
                window.location.href = '/Shop/Index';
            }, 3000);
        }

        detailConnection.start().catch(err => console.error("Lỗi kết nối Detail SignalR: ", err));

    </script>
}