<div class="container-xl px-4 px-lg-5 sh-main">
    <div class="row g-4">

        <div class="col-lg-3 d-none d-lg-block">
            <div class="sh-sidebar sticky-top" style="top:24px;z-index:10">

                <div class="sh-sidebar-hdr">
                    <div class="sh-sbhdr-deco"></div>
                    <div class="sh-sidebar-hdr-left">
                        <div class="sh-sidebar-hdr-icon"><i class="bi bi-funnel-fill"></i></div>
                        <span>Bộ lọc tìm kiếm</span>
                    </div>
                    <a asp-page="./Index" class="sh-clear-btn" title="Xóa bộ lọc">
                        <i class="bi bi-x-circle"></i>
                    </a>
                </div>

                <form method="get" class="sh-filter-form">
                    @if (Model.CategoryId.HasValue)
                    {
                        <input type="hidden" asp-for="CategoryId" />
                    }
                    @if (!string.IsNullOrEmpty(Model.SortOrder))
                    {
                        <input type="hidden" asp-for="SortOrder" />
                    }

                    <div class="sh-filter-group">
                        <label class="sh-filter-label"><i class="bi bi-search me-1"></i> Từ khóa</label>
                        <div class="sh-search-wrap">
                            <input type="text" asp-for="SearchTerm" class="sh-search-input" placeholder="Tìm tên sản phẩm...">
                            <button class="sh-search-btn" type="submit"><i class="bi bi-search"></i></button>
                        </div>
                    </div>

                    <div class="sh-filter-group">
                        <label class="sh-filter-label"><i class="bi bi-currency-dollar me-1"></i> Khoảng giá (VNĐ)</label>
                        <div class="sh-price-chips">
                            <button type="button" class="sh-price-chip" onclick="setPrice(0,2000000)">Dưới 2tr</button>
                            <button type="button" class="sh-price-chip" onclick="setPrice(2000000,10000000)">2–10tr</button>
                            <button type="button" class="sh-price-chip" onclick="setPrice(10000000,30000000)">10–30tr</button>
                            <button type="button" class="sh-price-chip" onclick="setPrice(30000000,999999999)">Trên 30tr</button>
                        </div>
                        <div class="sh-price-row">
                            <input type="number" id="minPriceInp" asp-for="MinPrice" class="sh-price-input" placeholder="Thấp nhất">
                            <span class="sh-price-sep">—</span>
                            <input type="number" id="maxPriceInp" asp-for="MaxPrice" class="sh-price-input" placeholder="Cao nhất">
                        </div>
                        <button class="sh-apply-btn" type="submit"><i class="bi bi-check2 me-1"></i> Áp dụng</button>
                    </div>
                </form>

                <div class="sh-filter-group sh-cats-group">
                    <label class="sh-filter-label"><i class="bi bi-grid me-1"></i> Danh mục</label>
                    <a href="@Url.Page("./Index", new { searchTerm = Model.SearchTerm, minPrice = Model.MinPrice, maxPrice = Model.MaxPrice, sortOrder = Model.SortOrder })"
                       class="sh-cat-all @(Model.CategoryId == null ? "sh-cat-active" : "")">
                        <i class="bi bi-grid-fill me-2"></i> Tất cả sản phẩm
                    </a>

                    @if (allCats != null)
                    {
                        <div class="accordion accordion-flush sh-accordion" id="categoryAccordion">
                            @foreach (var parent in parentCats)
                            {
                                var childCats = allCats.Where(c => c.ParentId == parent.CategoryId).ToList();
                                bool isActiveParent = (Model.CategoryId == parent.CategoryId);
                                bool isActiveChild = childCats.Any(c => c.CategoryId == Model.CategoryId);
                                bool expand = isActiveParent || isActiveChild;

                                <div class="accordion-item sh-acc-item">
                                    <h2 class="accordion-header">
                                        <button class="accordion-button sh-acc-btn @(expand ? "" : "collapsed") @(isActiveParent ? "sh-acc-active" : "")"
                                                type="button" data-bs-toggle="collapse"
                                                data-bs-target="#cat-@parent.CategoryId"
                                                aria-expanded="@(expand ? "true" : "false")">
                                            <span onclick="window.location.href='@Url.Page("./Index", new { categoryId = parent.CategoryId, searchTerm = Model.SearchTerm, sortOrder = Model.SortOrder })'; event.stopPropagation();">
                                                @parent.CategoryName
                                            </span>
                                        </button>
                                    </h2>
                                    <div id="cat-@parent.CategoryId"
                                         class="accordion-collapse collapse @(expand ? "show" : "")"
                                         data-bs-parent="#categoryAccordion">
                                        <div class="accordion-body sh-acc-body">
                                            <ul class="list-unstyled mb-0">
                                                @foreach (var child in childCats)
                                                {
                                                    <li>
                                                        <a href="@Url.Page("./Index", new { categoryId = child.CategoryId, searchTerm = Model.SearchTerm, minPrice = Model.MinPrice, maxPrice = Model.MaxPrice, sortOrder = Model.SortOrder })"
                                                           class="sh-child-link @(Model.CategoryId == child.CategoryId ? "sh-child-active" : "")">
                                                            <span class="sh-child-dot"></span>
                                                            @child.CategoryName
                                                        </a>
                                                    </li>
                                                }
                                            </ul>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>

                <div class="sh-sidebar-promo">
                    <div class="sh-sp-deco sh-sp-d1"></div>
                    <div class="sh-sp-deco sh-sp-d2"></div>
                    <div class="sh-sp-floats">
                        <i class="bi bi-lightning-charge-fill sh-sp-icon sh-sp-i1"></i>
                        <i class="bi bi-gift-fill sh-sp-icon sh-sp-i2"></i>
                        <i class="bi bi-star-fill sh-sp-icon sh-sp-i3"></i>
                    </div>
                    <span class="sh-sp-tag">🎉 Flash Sale</span>
                    <p class="sh-sp-title">Giảm đến <strong>50%</strong> hôm nay!</p>
                    <p class="sh-sp-sub">Chỉ còn hôm nay</p>
                    <a asp-page="./Index" class="sh-sp-btn">Xem ngay <i class="bi bi-arrow-right ms-1"></i></a>
                </div>

            </div>
        </div>

        <div class="col-lg-9 sh-product-col">
            <div class="sh-grid-bg" aria-hidden="true">
                <div class="sh-gb-blob sh-gb-b1"></div>
                <div class="sh-gb-blob sh-gb-b2"></div>
                <div class="sh-gb-blob sh-gb-b3"></div>
                <div class="sh-gb-dots"></div>
                <i class="sh-gb-icon sh-gbi-1 bi bi-phone-fill"></i>
                <i class="sh-gb-icon sh-gbi-2 bi bi-laptop-fill"></i>
                <i class="sh-gb-icon sh-gbi-3 bi bi-cpu-fill"></i>
                <i class="sh-gb-icon sh-gbi-4 bi bi-headphones"></i>
                <i class="sh-gb-icon sh-gbi-5 bi bi-watch"></i>
                <i class="sh-gb-icon sh-gbi-6 bi bi-camera-fill"></i>
                <i class="sh-gb-icon sh-gbi-7 bi bi-controller"></i>
                <i class="sh-gb-icon sh-gbi-8 bi bi-tablet-fill"></i>
                <svg class="sh-gb-svg" viewBox="0 0 900 700" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M0,120 L180,120 L180,200 L360,200" stroke="rgba(79,70,229,.09)" stroke-width="1.5" fill="none" />
                    <circle cx="180" cy="120" r="4" fill="rgba(79,70,229,.15)" />
                    <circle cx="360" cy="200" r="4" fill="rgba(79,70,229,.15)" />
                    <path d="M900,80 L720,80 L720,170 L540,170" stroke="rgba(236,72,153,.08)" stroke-width="1.5" fill="none" />
                    <circle cx="720" cy="80" r="4" fill="rgba(236,72,153,.15)" />
                    <path d="M0,400 L240,400 L240,320 L480,320" stroke="rgba(16,185,129,.07)" stroke-width="1.5" fill="none" />
                    <path d="M900,500 L660,500 L660,420 L420,420" stroke="rgba(245,158,11,.07)" stroke-width="1.5" fill="none" />
                    <path d="M200,700 L200,540 L400,540 L400,460" stroke="rgba(59,130,246,.07)" stroke-width="1.5" fill="none" />
                    <circle cx="200" cy="540" r="3" fill="rgba(59,130,246,.12)" />
                    <path d="M700,700 L700,580 L500,580 L500,500" stroke="rgba(124,58,237,.07)" stroke-width="1.5" fill="none" />
                    <circle cx="700" cy="580" r="3" fill="rgba(124,58,237,.12)" />
                </svg>
            </div>

            <div class="sh-toolbar sh-reveal-up">
                <div class="sh-toolbar-left">
                    <div class="sh-result-icon"><i class="bi bi-box-seam-fill"></i></div>
                    <span class="sh-result-count">
                        Hiển thị <strong>@(Model.Products?.Count() ?? 0)</strong> sản phẩm
                    </span>
                    @if (!string.IsNullOrEmpty(Model.SearchTerm))
                    {
                        <span class="sh-search-tag">
                            <i class="bi bi-search me-1"></i> "@Model.SearchTerm"
                            <a href="@Url.Page("./Index", new { categoryId = Model.CategoryId, minPrice = Model.MinPrice, maxPrice = Model.MaxPrice, sortOrder = Model.SortOrder })" class="sh-tag-remove">
                                <i class="bi bi-x"></i>
                            </a>
                        </span>
                    }
                </div>
                <div class="dropdown">
                    <button class="sh-sort-btn dropdown-toggle" type="button" data-bs-toggle="dropdown">
                        <i class="bi bi-arrow-down-up me-2"></i>
                        <span>@(Model.SortOrder == "price_asc" ? "Giá tăng dần" : "Giá giảm dần")</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end sh-dropdown">
                        <li>
                            <a class="dropdown-item sh-drop-item @(Model.SortOrder != "price_asc" ? "active" : "")"
                               href="@GetSortUrl("price_desc")">
                                <i class="bi bi-sort-numeric-down-alt me-2"></i> Giá giảm dần
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item sh-drop-item @(Model.SortOrder == "price_asc" ? "active" : "")"
                               href="@GetSortUrl("price_asc")">
                                <i class="bi bi-sort-numeric-up me-2"></i> Giá tăng dần
                            </a>
                        </li>
                    </ul>
                </div>
            </div>

            @if (Model.Products != null && Model.Products.Any())
            {
                <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-4" id="productGrid">
                    @foreach (var item in Model.Products)
                    {
                        <div class="col sh-reveal-up" id="product-card-@item.ProductId">
                            <div class="sh-card">
                                <div class="sh-card-stripe"></div>

                                <div class="sh-card-img-wrap">
                                    <span class="sh-badge-hot">
                                        <i class="bi bi-lightning-charge-fill me-1"></i>HOT
                                    </span>

                                    <button class="sh-wishlist-btn wishlist-toggle"
                                            data-product-id="@item.ProductId"
                                            title="Thêm vào yêu thích"
                                            style="z-index: 20; position: absolute; top: 10px; right: 10px;">
                                        <i class="bi bi-heart fs-5 wishlist-icon text-secondary"></i>
                                    </button>

                                    <a asp-page="./Details" asp-route-id="@item.ProductId" class="sh-img-link">
                                        <img src="@(string.IsNullOrEmpty(item.Image) ? "https://placehold.co/400x400/f8fafc/94a3b8?text=No+Image" : item.Image)"
                                             class="sh-product-img product-img p-img"
                                             alt="@item.ProductName"
                                             loading="lazy">
                                    </a>

                                    <div class="sh-card-overlay"></div>

                                    <div class="sh-actions product-actions">
                                        <button class="sh-action-btn btn-add-cart"
                                                title="Thêm vào giỏ"
                                                onclick="addToCart(@item.ProductId, this)">
                                            <i class="bi bi-cart-plus"></i>
                                        </button>
                                        <a asp-page="./Details"
                                           asp-route-id="@item.ProductId"
                                           class="sh-action-btn"
                                           title="Xem chi tiết">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </div>
                                </div>

                                <div class="sh-card-body">
                                    <div class="sh-cat-tag p-cat">@item.CategoryName</div>
                                    <h6 class="sh-product-name">
                                        <a asp-page="./Details" asp-route-id="@item.ProductId" class="sh-product-link p-name">
                                            @item.ProductName
                                        </a>
                                    </h6>
                                    <div class="sh-stars">
                                        <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i>
                                        <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i>
                                        <i class="bi bi-star-half"></i>
                                        <span class="sh-star-val">4.5 (128)</span>
                                    </div>
                                    <div class="sh-card-foot">
                                        <div>
                                            <span class="sh-price p-price">@item.Price.ToString("N0") ₫</span>
                                            <div class="sh-free-ship"><i class="bi bi-truck me-1"></i>Freeship</div>
                                        </div>
                                        <button class="sh-cart-quick btn-add-cart"
                                                onclick="addToCart(@item.ProductId, this)"
                                                title="Thêm vào giỏ">
                                            <i class="bi bi-cart-plus"></i>
                                        </button>
                                    </div>
                                </div>

                                <div class="sh-card-shine"></div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="sh-empty sh-reveal-up">
                    <div class="sh-empty-ring sh-er1"></div>
                    <div class="sh-empty-ring sh-er2"></div>
                    <div class="sh-empty-ring sh-er3"></div>
                    <div class="sh-empty-illus">
                        <svg viewBox="0 0 200 180" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <rect x="50" y="80" width="100" height="80" rx="8" fill="rgba(124,58,237,.1)" stroke="rgba(124,58,237,.2)" stroke-width="2" />
                            <path d="M45 80 L55 55 L145 55 L155 80" fill="rgba(124,58,237,.07)" stroke="rgba(124,58,237,.2)" stroke-width="2" />
                            <path d="M100 55 L110 30 L170 30 L160 55" fill="rgba(124,58,237,.06)" stroke="rgba(124,58,237,.18)" stroke-width="2" />
                            <text x="28" y="60" fill="rgba(245,158,11,.5)" font-size="14">✦</text>
                            <text x="162" y="50" fill="rgba(79,70,229,.4)" font-size="10">✧</text>
                            <text x="165" y="110" fill="rgba(236,72,153,.4)" font-size="12">✦</text>
                            <text x="24" y="120" fill="rgba(16,185,129,.4)" font-size="9">✧</text>
                            <circle cx="100" cy="118" r="22" fill="rgba(124,58,237,.06)" stroke="rgba(124,58,237,.15)" stroke-width="2" />
                            <line x1="116" y1="134" x2="126" y2="144" stroke="rgba(124,58,237,.2)" stroke-width="3" stroke-linecap="round" />
                            <text x="93" y="126" fill="rgba(124,58,237,.3)" font-size="20" font-weight="bold">?</text>
                        </svg>
                    </div>
                    <h4 class="sh-empty-title">Không tìm thấy sản phẩm nào</h4>
                    <p class="sh-empty-sub">Hãy thử thay đổi bộ lọc hoặc từ khóa tìm kiếm.</p>
                    <a asp-page="./Index" class="sh-empty-btn">
                        <i class="bi bi-arrow-repeat me-2"></i> Xóa bộ lọc &amp; Tải lại
                    </a>
                </div>
            }

        </div>
    </div>
    <div class="toast-container position-fixed top-0 end-0 p-3 mt-5" style="z-index: 9999">
        <div id="cartToast" class="toast align-items-center text-white bg-success border-0 shadow-lg" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body fs-6 fw-bold"><i class="bi bi-check-circle-fill me-2"></i> Đã thêm vào giỏ hàng!</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    </div>
</div>


@section Styles {
    <style>
        /* ══ Đảm bảo layout header / footer / navbar luôn TRÊN aurora (fixed z-index:0) ══
           Aurora dùng position:fixed nên theo CSS paint order nó đè lên static elements.
           Thêm z-index:1 cho các thẻ layout để chúng hiển thị đúng. ══ */
        body > header,
        body > footer,
        body > nav,
        .navbar,
        nav[class*="navbar"],
        footer[class],
        footer {
            position: relative !important;
            z-index: 1 !important;
        }

        :root {
            --sh-w: #fff;
            --sh-bg: #f8fafc;
            --sh-border: #e2e8f0;
            --sh-dark: #0f172a;
            --sh-text: #334155;
            --sh-muted: #64748b;
            --sh-blue: #3b82f6;
            --sh-blue-lt: #eff6ff;
            --sh-violet: #7c3aed;
            --sh-violet-lt: #f5f3ff;
            --sh-em: #10b981;
            --sh-em-lt: #ecfdf5;
            --sh-amb: #f59e0b;
            --sh-amb-lt: #fffbeb;
            --sh-g: linear-gradient(135deg,#4f46e5 0%,#7c3aed 55%,#ec4899 100%);
            --sh-g-price: linear-gradient(135deg,#4f46e5,#7c3aed);
            --sh-sh-sm: 0 2px 8px rgba(0,0,0,.07),0 8px 24px rgba(0,0,0,.06);
            --sh-sh-md: 0 4px 20px rgba(0,0,0,.09),0 16px 48px rgba(0,0,0,.07);
            --sh-sh-lg: 0 12px 48px rgba(0,0,0,.13),0 4px 14px rgba(0,0,0,.07);
            --sh-r: 16px;
        }

        * {
            box-sizing: border-box;
        }

        /* ══ PAGE SECTIONS — trên aurora, body giữ màu layout gốc ══ */
        .sh-hero, .sh-main {
            position: relative;
            z-index: 1;
        }

        .sh-main {
            background: transparent !important;
            border-radius: 0;
            margin-top: 0;
        }

            .sh-main::before, .sh-main::after {
                display: none;
            }

        /* ══ AURORA LAYER — covers full viewport with vivid gradient ══ */
        .sh-aurora {
            position: fixed;
            inset: 0;
            z-index: 0;
            overflow: hidden;
            pointer-events: none;
            /* Opaque base — visually replaces layout body white */
            background: linear-gradient(135deg,#e8e0ff 0%,#f5d9f7 28%,#daeeff 60%,#ffebd9 100%);
        }
            /* Dot grid overlay on aurora */
            .sh-aurora::before {
                content: '';
                position: absolute;
                inset: 0;
                background-image: radial-gradient(rgba(99,60,180,.085) 1.5px,transparent 1.5px);
                background-size: 24px 24px;
                z-index: 0;
            }

        /* ══ LARGE TECH SILHOUETTES ══ */
        .sh-tech-sil {
            position: absolute;
            pointer-events: none;
            will-change: transform;
        }

        .sh-sil-phone {
            right: -28px;
            bottom: 6%;
            width: 170px;
            color: rgba(109,40,217,.17);
            animation: sh-sil-float 9s ease-in-out infinite;
            filter: drop-shadow(0 0 20px rgba(109,40,217,.13));
        }

        .sh-sil-laptop {
            left: -55px;
            top: 22%;
            width: 300px;
            color: rgba(236,72,153,.14);
            animation: sh-sil-float 11s ease-in-out infinite;
            animation-delay: -4s;
            filter: drop-shadow(0 0 20px rgba(236,72,153,.11));
        }

        .sh-sil-phone2 {
            right: 4%;
            top: 7%;
            width: 80px;
            color: rgba(6,182,212,.13);
            animation: sh-sil-float 7s ease-in-out infinite;
            animation-delay: -2s;
        }
        @@keyframes sh-sil-float {
            0%,100%

        {
            transform: translateY(0) rotate(-2deg);
        }

        50% {
            transform: translateY(-22px) rotate(2.5deg);
        }

        }

        /* ══ SHOOTING STARS ══ */
        .sh-shoot {
            position: absolute;
            height: 2px;
            width: var(--w,130px);
            top: var(--t,20%);
            left: var(--l,-160px);
            background: linear-gradient(90deg,transparent 0%,var(--c,rgba(109,40,217,.85)) 50%,rgba(255,255,255,.9) 62%,transparent 100%);
            border-radius: 2px;
            animation: sh-shoot-go var(--dur,6s) linear infinite;
            animation-delay: var(--d,0s);
            opacity: 0;
        }
        @@keyframes sh-shoot-go {
            0%

        {
            transform: translate(0,0) rotate(-28deg);
            opacity: 0;
        }

        6% {
            opacity: 1;
        }

        88% {
            opacity: .9;
        }

        100% {
            transform: translate(115vw,calc(115vw*.55)) rotate(-28deg);
            opacity: 0;
        }

        }

        .sh-aurora-blob {
            position: absolute;
            border-radius: 50%;
            filter: blur(88px);
            will-change: transform;
        }
        /* Violet top-left */
        .sh-ab1 {
            width: 650px;
            height: 650px;
            top: -180px;
            left: -180px;
            background: radial-gradient(circle,rgba(109,40,217,.32) 0%,rgba(124,58,237,.18) 40%,transparent 70%);
            animation: sh-aur1 18s ease-in-out infinite;
        }
        /* Pink top-right */
        .sh-ab2 {
            width: 550px;
            height: 550px;
            top: -120px;
            right: -120px;
            background: radial-gradient(circle,rgba(236,72,153,.28) 0%,rgba(251,113,133,.16) 40%,transparent 70%);
            animation: sh-aur2 22s ease-in-out infinite;
            animation-delay: -6s;
        }
        /* Cyan bottom-center */
        .sh-ab3 {
            width: 700px;
            height: 700px;
            bottom: -200px;
            left: 28%;
            background: radial-gradient(circle,rgba(6,182,212,.22) 0%,rgba(59,130,246,.14) 40%,transparent 68%);
            animation: sh-aur3 26s ease-in-out infinite;
            animation-delay: -12s;
        }
        /* Amber bottom-right */
        .sh-ab4 {
            width: 480px;
            height: 480px;
            bottom: -120px;
            right: -100px;
            background: radial-gradient(circle,rgba(245,158,11,.24) 0%,rgba(251,191,36,.14) 40%,transparent 68%);
            animation: sh-aur1 20s ease-in-out infinite reverse;
            animation-delay: -4s;
        }
        /* Emerald mid-left */
        .sh-ab5 {
            width: 400px;
            height: 400px;
            top: 40%;
            left: -80px;
            background: radial-gradient(circle,rgba(16,185,129,.20) 0%,rgba(52,211,153,.12) 40%,transparent 68%);
            animation: sh-aur2 24s ease-in-out infinite;
            animation-delay: -9s;
        }
        @@keyframes sh-aur1 {
            0%,100%

        {
            transform: translate(0,0) scale(1);
        }

        33% {
            transform: translate(90px,-70px) scale(1.18);
        }

        66% {
            transform: translate(-60px,90px) scale(0.88);
        }

        }
        @@keyframes sh-aur2 {
            0%,100%

        {
            transform: translate(0,0) scale(1);
        }

        40% {
            transform: translate(-100px,80px) scale(1.12);
        }

        70% {
            transform: translate(70px,-60px) scale(0.93);
        }

        }
        @@keyframes sh-aur3 {
            0%,100%

        {
            transform: translate(0,0) scale(1);
        }

        25% {
            transform: translate(80px,-100px) scale(1.22);
        }

        75% {
            transform: translate(-90px,70px) scale(0.84);
        }

        }
        /* Floating sparkle stars */
        .sh-aur-star {
            position: absolute;
            font-style: normal;
            font-size: var(--sz,16px);
            color: var(--c,rgba(124,58,237,.5));
            animation: sh-aur-twinkle 3.5s ease-in-out infinite;
            animation-delay: var(--d,0s);
            pointer-events: none;
        }
        @@keyframes sh-aur-twinkle {
            0%,100%

        {
            opacity: .25;
            transform: scale(.8) rotate(0deg);
        }

        50% {
            opacity: 1;
            transform: scale(1.35) rotate(18deg);
        }

        }

        /* ══ HERO ══ */
        .sh-hero {
            position: relative;
            overflow: hidden;
            background: #fff;
            padding: 72px 0 64px;
            margin-bottom: 48px;
            border-bottom: 1px solid var(--sh-border);
        }

        .sh-dot-grid {
            position: absolute;
            inset: 0;
            pointer-events: none;
            background-image: radial-gradient(rgba(79,70,229,.1) 1.5px,transparent 1.5px);
            background-size: 28px 28px;
        }

        .sh-hero-blob {
            position: absolute;
            border-radius: 50%;
            filter: blur(80px);
            pointer-events: none;
        }

        .sh-hb1 {
            width: 500px;
            height: 500px;
            top: -180px;
            left: -80px;
            background: radial-gradient(circle,rgba(79,70,229,.13) 0%,transparent 70%);
            animation: sh-blob 10s ease-in-out infinite;
        }

        .sh-hb2 {
            width: 400px;
            height: 400px;
            bottom: -160px;
            right: -60px;
            background: radial-gradient(circle,rgba(236,72,153,.1) 0%,transparent 70%);
            animation: sh-blob 13s ease-in-out infinite reverse;
            animation-delay: 2s;
        }

        .sh-hb3 {
            width: 300px;
            height: 300px;
            top: 30%;
            right: 20%;
            background: radial-gradient(circle,rgba(59,130,246,.07) 0%,transparent 70%);
            animation: sh-blob 9s ease-in-out infinite;
            animation-delay: 1s;
        }
        @@keyframes sh-blob {
            0%,100%

        {
            transform: translate(0,0) scale(1);
        }

        50% {
            transform: translate(20px,-15px) scale(1.1);
        }

        }

        /* hero deco SVG corners */
        .sh-hero-deco {
            position: absolute;
            pointer-events: none;
            animation: sh-float-slow 7s ease-in-out infinite;
        }

        .sh-hd1 {
            top: 8%;
            left: 0%;
            width: 80px;
            animation-delay: 0s;
        }

        .sh-hd2 {
            top: 6%;
            right: 0%;
            width: 120px;
            animation-delay: 1s;
        }

        .sh-hd3 {
            bottom: 6%;
            left: 0%;
            width: 90px;
            animation-delay: 2s;
        }

        .sh-hd4 {
            bottom: 8%;
            right: 0%;
            width: 100px;
            animation-delay: 1.5s;
        }
        @@keyframes sh-float-slow {
            0%,100%

        {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-12px);
        }

        }

        /* sparkles */
        .sh-sp {
            position: absolute;
            pointer-events: none;
            color: var(--c,rgba(79,70,229,.4));
            animation: sh-sparkle 3s ease-in-out infinite;
            animation-delay: var(--d,0s);
        }
        @@keyframes sh-sparkle {
            0%,100%

        {
            opacity: .3;
            transform: scale(1) rotate(0deg);
        }

        50% {
            opacity: 1;
            transform: scale(1.4) rotate(20deg);
        }

        }

        .sh-hero-inner {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 40px;
            flex-wrap: wrap;
        }

        .sh-hero-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: linear-gradient(135deg,#eff6ff,#f5f3ff);
            border: 1px solid #ddd6fe;
            color: var(--sh-violet);
            padding: 6px 14px;
            border-radius: 50px;
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 16px;
        }

        .sh-ey-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: var(--sh-violet);
            display: inline-block;
            animation: sh-pulse 2s ease-in-out infinite;
        }
        @@keyframes sh-pulse {
            0%,100%

        {
            opacity: 1;
            transform: scale(1);
        }

        50% {
            opacity: .3;
            transform: scale(1.6);
        }

        }

        .sh-hero-title {
            font-size: clamp(1.9rem,3.6vw,2.9rem);
            font-weight: 900;
            line-height: 1.1;
            color: var(--sh-dark);
            margin-bottom: 14px;
            letter-spacing: -1.5px;
        }

        .sh-grad-text {
            background: var(--sh-g);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            background-size: 200% auto;
            animation: sh-grad 4s linear infinite;
        }
        @@keyframes sh-grad {
            0%

        {
            background-position: 0% 50%;
        }

        50% {
            background-position: 100% 50%;
        }

        100% {
            background-position: 0% 50%;
        }

        }

        .sh-hero-sub {
            font-size: 15px;
            color: var(--sh-muted);
            margin: 0 0 24px;
        }

        .sh-hero-right {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        /* Category quick links */
        .sh-hero-cats {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
        }
        /* Decorative display cards — không phải nút bấm, chỉ đẹp */
        .sh-hero-cat {
            display: flex;
            align-items: center;
            gap: 10px;
            background: #fff;
            border: 1px solid var(--sh-border);
            border-radius: 12px;
            padding: 10px 14px;
            color: var(--sh-dark);
            font-size: 13px;
            font-weight: 600;
            transition: all .3s ease;
            box-shadow: 0 2px 8px rgba(0,0,0,.05);
            cursor: default;
            user-select: none;
            position: relative;
            overflow: hidden;
        }
            /* shimmer sweep khi hover */
            .sh-hero-cat::after {
                content: '';
                position: absolute;
                inset: 0;
                background: linear-gradient(105deg,transparent 40%,rgba(255,255,255,.55) 50%,transparent 60%);
                transform: translateX(-100%);
                transition: transform .5s ease;
                pointer-events: none;
            }

            .sh-hero-cat:hover::after {
                transform: translateX(100%);
            }
            /* icon nhún nhẹ, card sáng lên theo màu riêng — không translateY kiểu nút */
            .sh-hero-cat:hover {
                box-shadow: 0 6px 20px rgba(0,0,0,.09);
            }

                .sh-hero-cat:hover .sh-hc-icon {
                    transform: scale(1.13);
                    transition: transform .3s ease;
                }

        .sh-hc-icon {
            width: 34px;
            height: 34px;
            border-radius: 9px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 17px;
            flex-shrink: 0;
            transition: transform .3s ease;
        }
        /* màu border-top + icon theo từng loại */
        .sh-hc-blue {
            border-top: 2px solid var(--sh-blue);
        }

            .sh-hc-blue .sh-hc-icon {
                background: var(--sh-blue-lt);
                color: var(--sh-blue);
            }

            .sh-hc-blue:hover {
                border-color: var(--sh-blue);
                box-shadow: 0 6px 20px rgba(59,130,246,.15);
            }

        .sh-hc-violet {
            border-top: 2px solid var(--sh-violet);
        }

            .sh-hc-violet .sh-hc-icon {
                background: var(--sh-violet-lt);
                color: var(--sh-violet);
            }

            .sh-hc-violet:hover {
                border-color: var(--sh-violet);
                box-shadow: 0 6px 20px rgba(124,58,237,.15);
            }

        .sh-hc-em {
            border-top: 2px solid var(--sh-em);
        }

            .sh-hc-em .sh-hc-icon {
                background: var(--sh-em-lt);
                color: var(--sh-em);
            }

            .sh-hc-em:hover {
                border-color: var(--sh-em);
                box-shadow: 0 6px 20px rgba(16,185,129,.15);
            }

        .sh-hc-amb {
            border-top: 2px solid var(--sh-amb);
        }

            .sh-hc-amb .sh-hc-icon {
                background: var(--sh-amb-lt);
                color: var(--sh-amb);
            }

            .sh-hc-amb:hover {
                border-color: var(--sh-amb);
                box-shadow: 0 6px 20px rgba(245,158,11,.15);
            }

        .sh-hero-pills {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .sh-hero-pill {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: #fff;
            border: 1px solid var(--sh-border);
            color: var(--sh-text);
            padding: 6px 12px;
            border-radius: 50px;
            font-size: 12px;
            font-weight: 600;
            box-shadow: 0 2px 6px rgba(0,0,0,.05);
            white-space: nowrap;
        }

            .sh-hero-pill i {
                color: var(--sh-violet);
            }

        /* ══ MAIN — transparent, body đã đảm nhận full background ══ */
        .sh-main {
            padding-bottom: 80px;
            position: relative;
        }

            .sh-main > .row {
                position: relative;
                z-index: 1;
            }

        /* ══ SIDEBAR ══ */
        .sh-sidebar {
            background: var(--sh-w);
            border: 1px solid var(--sh-border);
            border-radius: var(--sh-r);
            overflow: hidden;
            box-shadow: var(--sh-sh-sm);
        }

        .sh-sidebar-hdr {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 18px 20px 14px;
            border-bottom: 1px solid var(--sh-border);
            background: linear-gradient(135deg,#f5f3ff,#fff);
            position: relative;
            overflow: hidden;
        }

        .sh-sbhdr-deco {
            position: absolute;
            top: -20px;
            right: -20px;
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: rgba(124,58,237,.07);
            pointer-events: none;
        }

        .sh-sidebar-hdr-left {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 15px;
            font-weight: 800;
            color: var(--sh-dark);
            position: relative;
            z-index: 1;
        }

        .sh-sidebar-hdr-icon {
            width: 34px;
            height: 34px;
            border-radius: 9px;
            background: var(--sh-g);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 15px;
        }

        .sh-clear-btn {
            color: var(--sh-muted);
            font-size: 18px;
            text-decoration: none;
            transition: color .2s;
            line-height: 1;
            position: relative;
            z-index: 1;
        }

            .sh-clear-btn:hover {
                color: #ef4444;
            }

        .sh-filter-form {
            padding: 4px 0;
        }

        .sh-filter-group {
            padding: 16px 20px;
            border-bottom: 1px solid var(--sh-border);
        }

            .sh-filter-group:last-child {
                border-bottom: none;
            }

        .sh-filter-label {
            display: block;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--sh-muted);
            margin-bottom: 10px;
        }

        .sh-search-wrap {
            display: flex;
            border-radius: 10px;
            overflow: hidden;
            border: 1px solid var(--sh-border);
        }

        .sh-search-input {
            flex: 1;
            border: none;
            padding: 9px 14px;
            font-size: 14px;
            color: var(--sh-dark);
            background: #fff;
            outline: none;
        }

            .sh-search-input:focus {
                background: #f5f3ff;
            }

        .sh-search-btn {
            background: var(--sh-g);
            color: #fff;
            border: none;
            padding: 0 16px;
            font-size: 15px;
            cursor: pointer;
            transition: .2s;
        }

            .sh-search-btn:hover {
                opacity: .9;
            }

        /* price chips */
        .sh-price-chips {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            margin-bottom: 10px;
        }

        .sh-price-chip {
            background: var(--sh-bg);
            border: 1px solid var(--sh-border);
            border-radius: 6px;
            padding: 4px 10px;
            font-size: 11px;
            font-weight: 600;
            color: var(--sh-muted);
            cursor: pointer;
            transition: .2s;
        }

            .sh-price-chip:hover {
                background: var(--sh-violet-lt);
                border-color: #ddd6fe;
                color: var(--sh-violet);
            }
        /* Price inputs — stack vertically so numbers aren't clipped */
        .sh-price-row {
            display: flex;
            flex-direction: column;
            gap: 8px;
            margin-bottom: 10px;
        }

        .sh-price-sep {
            display: none;
        }
        /* hide "—" separator, no longer needed in column layout */
        .sh-price-input {
            width: 100%;
            min-width: 0;
            border: 1px solid var(--sh-border);
            border-radius: 8px;
            padding: 8px 12px;
            font-size: 13px;
            color: var(--sh-dark);
            outline: none;
            transition: .2s;
            /* show up to 9 digits comfortably */
            appearance: textfield;
            -moz-appearance: textfield;
        }

            .sh-price-input::-webkit-inner-spin-button,
            .sh-price-input::-webkit-outer-spin-button {
                -webkit-appearance: none;
                margin: 0;
            }

            .sh-price-input:focus {
                border-color: #c4b5fd;
                box-shadow: 0 0 0 3px rgba(124,58,237,.08);
            }
        /* small placeholder labels above each input */
        .sh-price-row .sh-price-input:first-of-type {
            order: 1;
        }

        .sh-price-row .sh-price-input:last-of-type {
            order: 2;
        }

        .sh-apply-btn {
            width: 100%;
            background: var(--sh-violet-lt);
            color: var(--sh-violet);
            border: 1px solid #ddd6fe;
            border-radius: 8px;
            padding: 8px;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            transition: .2s;
        }

            .sh-apply-btn:hover {
                background: var(--sh-g);
                color: #fff;
                border-color: transparent;
            }

        .sh-cats-group {
            padding-bottom: 20px;
        }

        .sh-cat-all {
            display: flex;
            align-items: center;
            padding: 8px 4px;
            font-size: 14px;
            font-weight: 600;
            color: var(--sh-text);
            text-decoration: none;
            border-radius: 8px;
            transition: .2s;
            margin-bottom: 4px;
        }

            .sh-cat-all:hover, .sh-cat-all.sh-cat-active {
                color: var(--sh-violet);
            }

        .sh-accordion {
            --bs-accordion-bg: transparent;
            --bs-accordion-border-color: transparent;
        }

        .sh-acc-item {
            background: transparent;
            border: none !important;
        }

        .sh-acc-btn {
            background: transparent !important;
            color: var(--sh-text) !important;
            font-size: 14px;
            font-weight: 600;
            padding: 8px 4px !important;
            box-shadow: none !important;
            transition: color .2s;
        }

            .sh-acc-btn:not(.collapsed), .sh-acc-btn.sh-acc-active {
                color: var(--sh-violet) !important;
            }

            .sh-acc-btn::after {
                filter: none !important;
            }

        .sh-acc-body {
            padding: 4px 0 4px 8px !important;
        }

        .sh-child-link {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 6px 8px;
            border-radius: 7px;
            font-size: 13px;
            color: var(--sh-muted);
            text-decoration: none;
            transition: .2s;
        }

            .sh-child-link:hover, .sh-child-link.sh-child-active {
                background: var(--sh-violet-lt);
                color: var(--sh-violet);
            }

            .sh-child-link.sh-child-active {
                font-weight: 700;
            }

        .sh-child-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: currentColor;
            flex-shrink: 0;
        }

        /* Sidebar promo banner */
        .sh-sidebar-promo {
            margin: 16px 16px 20px;
            border-radius: 14px;
            padding: 20px 18px;
            background: linear-gradient(135deg,#4f46e5 0%,#7c3aed 55%,#ec4899 100%);
            position: relative;
            overflow: hidden;
        }

        .sh-sp-deco {
            position: absolute;
            border-radius: 50%;
            pointer-events: none;
        }

        .sh-sp-d1 {
            width: 100px;
            height: 100px;
            top: -30px;
            right: -30px;
            background: rgba(255,255,255,.1);
        }

        .sh-sp-d2 {
            width: 60px;
            height: 60px;
            bottom: -20px;
            left: -10px;
            background: rgba(255,255,255,.07);
        }

        .sh-sp-floats {
            position: absolute;
            inset: 0;
            pointer-events: none;
        }

        .sh-sp-icon {
            position: absolute;
            color: rgba(255,255,255,.15);
            font-size: 22px;
            animation: sh-float-slow 4s ease-in-out infinite;
        }

        .sh-sp-i1 {
            top: 8%;
            right: 18%;
            animation-delay: 0s;
        }

        .sh-sp-i2 {
            bottom: 12%;
            right: 10%;
            animation-delay: .8s;
            font-size: 18px;
        }

        .sh-sp-i3 {
            top: 40%;
            right: 6%;
            animation-delay: 1.6s;
            font-size: 16px;
        }

        .sh-sp-tag {
            display: inline-block;
            background: rgba(255,255,255,.2);
            border: 1px solid rgba(255,255,255,.3);
            color: #fff;
            padding: 3px 10px;
            border-radius: 50px;
            font-size: 11px;
            font-weight: 700;
            margin-bottom: 8px;
            position: relative;
            z-index: 1;
        }

        .sh-sp-title {
            color: #fff;
            font-size: 16px;
            font-weight: 800;
            margin: 0 0 4px;
            position: relative;
            z-index: 1;
        }

            .sh-sp-title strong {
                font-size: 22px;
            }

        .sh-sp-sub {
            color: rgba(255,255,255,.7);
            font-size: 12px;
            margin: 0 0 12px;
            position: relative;
            z-index: 1;
        }

        .sh-sp-btn {
            display: inline-flex;
            align-items: center;
            background: rgba(255,255,255,.2);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255,255,255,.3);
            color: #fff;
            padding: 8px 16px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 700;
            text-decoration: none;
            transition: .2s;
            position: relative;
            z-index: 1;
        }

            .sh-sp-btn:hover {
                background: rgba(255,255,255,.3);
                color: #fff;
            }

        /* ══ TOOLBAR ══ */
        .sh-toolbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: #fff;
            border: 1px solid var(--sh-border);
            border-radius: var(--sh-r);
            padding: 14px 20px;
            margin-bottom: 24px;
            box-shadow: var(--sh-sh-sm);
            flex-wrap: wrap;
            gap: 12px;
        }

        .sh-toolbar-left {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
        }

        .sh-result-icon {
            width: 30px;
            height: 30px;
            border-radius: 8px;
            background: var(--sh-violet-lt);
            color: var(--sh-violet);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 15px;
        }

        .sh-result-count {
            font-size: 14px;
            color: var(--sh-text);
        }

            .sh-result-count strong {
                color: var(--sh-dark);
            }

        .sh-search-tag {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            background: var(--sh-violet-lt);
            color: var(--sh-violet);
            border: 1px solid #ddd6fe;
            border-radius: 50px;
            padding: 3px 12px 3px 10px;
            font-size: 12px;
            font-weight: 600;
        }

        .sh-tag-remove {
            color: var(--sh-violet);
            text-decoration: none;
            margin-left: 2px;
        }

            .sh-tag-remove:hover {
                color: #ef4444;
            }

        .sh-sort-btn {
            display: flex;
            align-items: center;
            gap: 6px;
            background: #fff;
            border: 1px solid var(--sh-border);
            border-radius: 10px;
            padding: 9px 16px;
            font-size: 13px;
            font-weight: 600;
            color: var(--sh-dark);
            cursor: pointer;
            transition: .2s;
        }

            .sh-sort-btn:hover {
                border-color: #c4b5fd;
                color: var(--sh-violet);
            }

            .sh-sort-btn span {
                color: var(--sh-violet);
            }

        .sh-dropdown {
            border: 1px solid var(--sh-border);
            border-radius: 12px;
            box-shadow: var(--sh-sh-md);
            padding: 6px;
            min-width: 180px;
            /* FIX: must appear ABOVE product cards (z-index:1) */
            z-index: 9999 !important;
        }
        /* Also boost the Bootstrap wrapper so the menu escapes card stacking contexts */
        .sh-toolbar {
            z-index: 200 !important;
            position: relative;
        }

            .sh-toolbar .dropdown {
                position: relative;
                z-index: 200;
            }

            .sh-toolbar .dropdown-menu {
                z-index: 9999 !important;
            }

        .sh-drop-item {
            border-radius: 8px;
            padding: 9px 14px;
            font-size: 13px;
            font-weight: 500;
            transition: .15s;
        }

            .sh-drop-item:hover, .sh-drop-item.active {
                background: var(--sh-violet-lt);
                color: var(--sh-violet) !important;
            }

        /* ══ PRODUCT CARD ══ */
        .sh-card {
            background: #fff;
            border: 1px solid var(--sh-border);
            border-radius: var(--sh-r);
            overflow: hidden;
            height: 100%;
            transition: all .3s cubic-bezier(.34,1.56,.64,1);
            display: flex;
            flex-direction: column;
            position: relative;
        }

            .sh-card:hover {
                transform: translateY(-8px);
                box-shadow: var(--sh-sh-lg);
                border-color: transparent;
            }

        /* color stripe */
        .sh-card-stripe {
            height: 3px;
            background: var(--sh-g);
            width: 100%;
            transition: height .3s;
        }

        .sh-card:hover .sh-card-stripe {
            height: 4px;
        }

        /* sh-card-img-wrap — defined fully later with gradient background */

        .sh-badge-hot {
            position: absolute;
            top: 10px;
            left: 10px;
            z-index: 3;
            background: linear-gradient(135deg,#ef4444,#ec4899);
            color: #fff;
            font-size: 10px;
            font-weight: 800;
            padding: 3px 10px;
            border-radius: 50px;
            letter-spacing: .3px;
            box-shadow: 0 4px 12px rgba(239,68,68,.35);
        }

        .sh-wishlist-btn {
            position: absolute;
            top: 10px;
            right: 10px;
            z-index: 3;
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: rgba(255,255,255,.88);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,.9);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #94a3b8;
            cursor: pointer;
            box-shadow: 0 2px 8px rgba(0,0,0,.1);
            transition: all .25s;
        }

            .sh-wishlist-btn:hover {
                background: #fff;
                color: #ef4444;
                transform: scale(1.12);
            }

        .sh-img-link {
            display: block;
            width: 100%;
            height: 100%;
        }

        .sh-product-img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            padding: 16px;
            transition: transform .4s ease;
        }

        .sh-card:hover .sh-product-img {
            transform: scale(1.07);
        }

        /* overlay pattern on hover */
        .sh-card-overlay {
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at center,rgba(79,70,229,.04),transparent 70%);
            opacity: 0;
            transition: opacity .3s;
            pointer-events: none;
        }

        .sh-card:hover .sh-card-overlay {
            opacity: 1;
        }

        .sh-actions {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 10px;
            padding: 14px;
            background: linear-gradient(to top,rgba(248,250,252,.92),transparent);
            opacity: 0;
            transform: translateY(16px);
            transition: all .3s ease;
        }

        .sh-card:hover .sh-actions {
            opacity: 1;
            transform: translateY(0);
        }

        .sh-action-btn {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            background: #fff;
            border: 1px solid var(--sh-border);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--sh-text);
            font-size: 17px;
            cursor: pointer;
            text-decoration: none;
            box-shadow: 0 2px 8px rgba(0,0,0,.1);
            transition: all .2s;
        }

            .sh-action-btn:hover {
                background: var(--sh-g);
                color: #fff;
                border-color: transparent;
                transform: scale(1.12);
                box-shadow: 0 6px 20px rgba(79,70,229,.35);
            }

        .sh-card-body {
            padding: 14px 16px;
            display: flex;
            flex-direction: column;
            gap: 5px;
            flex: 1;
        }

        .sh-cat-tag {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--sh-violet);
        }

        .sh-product-name {
            margin: 0;
            font-size: 14px;
            font-weight: 700;
            line-height: 1.4;
        }

        .sh-product-link {
            color: var(--sh-dark);
            text-decoration: none;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            transition: color .2s;
        }

            .sh-product-link:hover {
                color: var(--sh-violet);
            }

        .sh-stars {
            font-size: 11px;
            color: #f59e0b;
            display: flex;
            align-items: center;
            gap: 2px;
        }

        .sh-star-val {
            font-size: 11.5px;
            color: var(--sh-muted);
            margin-left: 4px;
        }

        .sh-card-foot {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            margin-top: auto;
            padding-top: 10px;
            border-top: 1px solid var(--sh-border);
        }

        .sh-price {
            font-size: 18px;
            font-weight: 900;
            background: var(--sh-g-price);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            display: block;
        }

        .sh-free-ship {
            font-size: 10.5px;
            font-weight: 600;
            color: var(--sh-em);
            margin-top: 2px;
        }

            .sh-free-ship i {
                font-size: 11px;
            }

        .sh-cart-quick {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: var(--sh-violet-lt);
            color: var(--sh-violet);
            border: 1px solid #ddd6fe;
            font-size: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all .2s;
            flex-shrink: 0;
        }

            .sh-cart-quick:hover {
                background: var(--sh-g);
                color: #fff;
                border-color: transparent;
            }

        /* card shine */
        .sh-card-shine {
            position: absolute;
            top: 0;
            left: -100%;
            width: 50%;
            height: 100%;
            background: linear-gradient(90deg,transparent,rgba(255,255,255,.06),transparent);
            transform: skewX(-15deg);
            transition: left .6s;
            pointer-events: none;
        }

        .sh-card:hover .sh-card-shine {
            left: 150%;
        }

        /* ══ PRODUCT COLUMN ANIMATED BG ══ */
        .sh-product-col {
            position: relative;
        }

        .sh-grid-bg {
            position: absolute;
            inset: 0;
            border-radius: 20px;
            overflow: hidden;
            pointer-events: none;
            z-index: 0;
            /* background removed — body now handles full-screen gradient */
        }

        .sh-gb-blob {
            position: absolute;
            border-radius: 50%;
            filter: blur(70px);
            pointer-events: none;
        }

        .sh-gb-b1 {
            width: 420px;
            height: 420px;
            top: -80px;
            left: -80px;
            background: radial-gradient(circle,rgba(79,70,229,.1) 0%,transparent 70%);
            animation: sh-blob 12s ease-in-out infinite;
        }

        .sh-gb-b2 {
            width: 360px;
            height: 360px;
            bottom: -60px;
            right: -60px;
            background: radial-gradient(circle,rgba(236,72,153,.09) 0%,transparent 70%);
            animation: sh-blob 14s ease-in-out infinite reverse;
            animation-delay: 2s;
        }

        .sh-gb-b3 {
            width: 280px;
            height: 280px;
            top: 45%;
            left: 55%;
            background: radial-gradient(circle,rgba(16,185,129,.07) 0%,transparent 70%);
            animation: sh-blob 10s ease-in-out infinite;
            animation-delay: 1s;
        }

        .sh-gb-dots {
            position: absolute;
            inset: 0;
            background-image: radial-gradient(rgba(79,70,229,.09) 1.5px,transparent 1.5px);
            background-size: 26px 26px;
        }
        /* floating ambient tech icons in grid bg */
        .sh-gb-icon {
            position: absolute;
            pointer-events: none;
            font-style: normal;
            animation: sh-float-slow 6s ease-in-out infinite;
        }

        .sh-gbi-1 {
            top: 4%;
            left: 3%;
            font-size: 44px;
            color: rgba(79,70,229,.08);
            animation-delay: 0s;
        }

        .sh-gbi-2 {
            top: 4%;
            right: 3%;
            font-size: 52px;
            color: rgba(124,58,237,.07);
            animation-delay: .8s;
        }

        .sh-gbi-3 {
            top: 30%;
            left: 1%;
            font-size: 38px;
            color: rgba(16,185,129,.07);
            animation-delay: 1.6s;
        }

        .sh-gbi-4 {
            top: 30%;
            right: 1%;
            font-size: 40px;
            color: rgba(245,158,11,.07);
            animation-delay: 2.4s;
        }

        .sh-gbi-5 {
            top: 57%;
            left: 2%;
            font-size: 36px;
            color: rgba(236,72,153,.07);
            animation-delay: 1.2s;
        }

        .sh-gbi-6 {
            top: 57%;
