@page
@model E_Commerce_Razor.Pages.Shop.IndexModel
@{
    ViewData["Title"] = "Cửa hàng";

    string GetSortUrl(string sortOrder)
    {
        return Url.Page("./Index", new
        {
            searchTerm = Model.SearchTerm,
            categoryId = Model.CategoryId,
            minPrice = Model.MinPrice,
            maxPrice = Model.MaxPrice,
            sortOrder = sortOrder
        });
    }

    var allCats = Model.Categories?.ToList();
    var parentCats = allCats?.Where(c => c.ParentId == null).ToList();
}

