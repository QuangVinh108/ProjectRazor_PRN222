            animation-delay: .4s;
        }

        .sh-gbi-8 {
            bottom: 5%;
            right: 4%;
            font-size: 44px;
            color: rgba(124,58,237,.07);
            animation-delay: 1.8s;
        }

        .sh-gb-svg {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
        }

        /* make toolbar, cards etc render above the background */
        .sh-toolbar, .sh-card, .sh-reveal-up, .sh-empty {
            position: relative;
            z-index: 1;
        }

        /* ══ IMAGE AREA — pure CSS decorative background (no extra HTML needed) ══ */
        .sh-card-img-wrap {
            position: relative;
            overflow: hidden;
            height: 220px;
            border-bottom: 1px solid var(--sh-border);
            background: linear-gradient(145deg,#f5f7ff 0%,#faf0ff 50%,#f0f9ff 100%);
        }

        .sh-card:hover .sh-card-img-wrap {
            border-color: transparent;
        }

        /* ::before — center radial glow + dot grid pattern */
        .sh-card-img-wrap::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image: radial-gradient(circle at 50% 50%, rgba(79,70,229,.07) 0%, rgba(124,58,237,.04) 40%, transparent 70%), radial-gradient(rgba(79,70,229,.07) 1.5px, transparent 1.5px);
            background-size: 100% 100%, 22px 22px;
            pointer-events: none;
            z-index: 0;
            animation: sh-glow-pulse 4s ease-in-out infinite;
        }
        @@keyframes sh-glow-pulse {
            0%,100%

        {
            opacity: .7;
        }

        50% {
            opacity: 1;
        }

        }

        /* ::after — spinning dashed ring */
        .sh-card-img-wrap::after {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 130px;
            height: 130px;
            transform: translate(-50%,-50%) rotate(0deg);
            border-radius: 50%;
            border: 1.5px dashed rgba(79,70,229,.12);
            pointer-events: none;
            z-index: 0;
            animation: sh-ring-spin 20s linear infinite;
        }
        @@keyframes sh-ring-spin {
            from

        {
            transform: translate(-50%,-50%) rotate(0deg);
        }

        to {
            transform: translate(-50%,-50%) rotate(360deg);
        }

        }

        /* Corner gradient glows via box-shadow inset trick */
        .sh-card-img-wrap .sh-img-link::before {
            content: '';
            position: absolute;
            inset: 0;
            z-index: 0;
            pointer-events: none;
            background: radial-gradient(circle at 5% 5%, rgba(79,70,229,.1) 0%, transparent 40%), radial-gradient(circle at 95% 5%, rgba(236,72,153,.09) 0%, transparent 40%), radial-gradient(circle at 5% 95%, rgba(16,185,129,.09) 0%, transparent 40%), radial-gradient(circle at 95% 95%, rgba(245,158,11,.09) 0%, transparent 40%);
        }

        /* make image and UI elements render above bg layers */
        /* ⚠ sh-wishlist-btn giữ nguyên position:absolute — KHÔNG override ở đây */
        .sh-img-link, .sh-badge-hot, .sh-actions, .sh-card-overlay {
            position: relative;
            z-index: 2;
        }

        .sh-product-img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            padding: 16px;
            transition: transform .4s ease;
            position: relative;
            z-index: 2;
        }

        .sh-card:hover .sh-product-img {
            transform: scale(1.07);
        }

        /* Per-card color variant backgrounds */
        .sh-card:nth-child(3n+1) .sh-card-img-wrap {
            background: linear-gradient(145deg,#f5f7ff,#faf0ff,#f0f9ff);
        }

            .sh-card:nth-child(3n+1) .sh-card-img-wrap::before {
                background-image: radial-gradient(circle at 50% 50%,rgba(79,70,229,.09) 0%,rgba(124,58,237,.05) 40%,transparent 70%),radial-gradient(rgba(79,70,229,.07) 1.5px,transparent 1.5px);
                background-size: 100% 100%,22px 22px;
            }

        .sh-card:nth-child(3n+2) .sh-card-img-wrap {
            background: linear-gradient(145deg,#f0fdf9,#eff6ff,#faf5ff);
        }

            .sh-card:nth-child(3n+2) .sh-card-img-wrap::before {
                background-image: radial-gradient(circle at 50% 50%,rgba(16,185,129,.09) 0%,rgba(59,130,246,.05) 40%,transparent 70%),radial-gradient(rgba(16,185,129,.07) 1.5px,transparent 1.5px);
                background-size: 100% 100%,22px 22px;
            }

            .sh-card:nth-child(3n+2) .sh-card-img-wrap::after {
                border-color: rgba(16,185,129,.12);
            }

        .sh-card:nth-child(3n) .sh-card-img-wrap {
            background: linear-gradient(145deg,#fdf4ff,#fff7ed,#fdf2f8);
        }

            .sh-card:nth-child(3n) .sh-card-img-wrap::before {
                background-image: radial-gradient(circle at 50% 50%,rgba(236,72,153,.09) 0%,rgba(245,158,11,.05) 40%,transparent 70%),radial-gradient(rgba(236,72,153,.07) 1.5px,transparent 1.5px);
                background-size: 100% 100%,22px 22px;
            }

            .sh-card:nth-child(3n) .sh-card-img-wrap::after {
                border-color: rgba(236,72,153,.12);
            }

        /* ══ EMPTY STATE ══ */
        .sh-empty {
            background: #fff;
            border: 1px solid var(--sh-border);
            border-radius: 24px;
            padding: 72px 32px;
            text-align: center;
            box-shadow: var(--sh-sh-sm);
            position: relative;
            overflow: hidden;
        }

        .sh-empty-ring {
            position: absolute;
            border-radius: 50%;
            border: 1px dashed rgba(124,58,237,.15);
            pointer-events: none;
        }

        .sh-er1 {
            width: 300px;
            height: 300px;
            top: 50%;
            left: 50%;
            transform: translate(-50%,-50%);
        }

        .sh-er2 {
            width: 460px;
            height: 460px;
            top: 50%;
            left: 50%;
            transform: translate(-50%,-50%);
        }

        .sh-er3 {
            width: 620px;
            height: 620px;
            top: 50%;
            left: 50%;
            transform: translate(-50%,-50%);
        }

        .sh-empty-illus {
            width: 200px;
            margin: 0 auto 20px;
            position: relative;
            z-index: 1;
        }

            .sh-empty-illus svg {
                width: 100%;
                height: auto;
            }

        .sh-empty-title {
            font-size: 20px;
            font-weight: 800;
            color: var(--sh-dark);
            margin-bottom: 8px;
            position: relative;
            z-index: 1;
        }

        .sh-empty-sub {
            font-size: 14px;
            color: var(--sh-muted);
            margin-bottom: 24px;
            position: relative;
            z-index: 1;
        }

        .sh-empty-btn {
            display: inline-flex;
            align-items: center;
            background: var(--sh-g);
            color: #fff;
            padding: 12px 28px;
            border-radius: 50px;
            font-size: 14px;
            font-weight: 700;
            text-decoration: none;
            box-shadow: 0 8px 24px rgba(79,70,229,.35);
            transition: .25s;
            position: relative;
            z-index: 1;
        }

            .sh-empty-btn:hover {
                transform: translateY(-3px);
                color: #fff;
                box-shadow: 0 14px 32px rgba(79,70,229,.45);
            }

        /* ══ SCROLL REVEAL ══ */
        .sh-reveal-up {
            opacity: 0;
            transform: translateY(32px);
            transition: opacity .65s cubic-bezier(.22,1,.36,1),transform .65s cubic-bezier(.22,1,.36,1);
        }

        .sh-revealed {
            opacity: 1;
            transform: none;
        }

        /* ══ RESPONSIVE ══ */
        @@media(max-width:991px) {
            .sh-hero {
                padding: 56px 0 48px;
            }

            .sh-hero-inner {
                flex-direction: column;
                gap: 24px;
            }

            .sh-hd2, .sh-hd3 {
                display: none;
            }

            .sh-hd1 {
                width: 60px;
            }

            .sh-hd4 {
                width: 70px;
            }
        }

        @@media(max-width:767px) {
            .sh-hero-title {
                font-size: 1.8rem;
            }

            .sh-hero-cats {
                grid-template-columns: 1fr 1fr;
            }

            .sh-hd1, .sh-hd2, .sh-hd3, .sh-hd4 {
                display: none;
            }

            .sh-hero-pills {
                display: none;
            }
        }

        @@media(max-width:575px) {
            .sh-card-img-wrap {
                height: 200px;
            }

            .sh-toolbar {
                flex-direction: column;
                align-items: flex-start;
            }
        }
    </style>
}


@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.12/signalr.min.js"></script>

    <script>
        // ─── 1. ADD TO CART (HIỂN THỊ THÔNG BÁO CHUẨN) ───
        async function addToCart(productId, btnElement) {
            const originalContent = btnElement.innerHTML;
            btnElement.disabled = true;
            btnElement.innerHTML = '<span class="spinner-border spinner-border-sm text-primary" role="status"></span>';

            const formData = new FormData();
            formData.append('productId', productId);

            // Xử lý số lượng: Nếu ở trang chi tiết có ô nhập số lượng thì lấy, nếu không mặc định là 1
            const qtyInput = document.querySelector('.quantity-input');
            formData.append('quantity', qtyInput ? qtyInput.value : 1);

            // Lấy token bảo mật
            const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
            const token = tokenInput ? tokenInput.value : '';
            if (token) formData.append('__RequestVerificationToken', token);

            try {
                const res = await fetch('/Cart/Add', {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: formData
                });

                // 1. Nếu chưa đăng nhập
                if (res.status === 401 || res.url.includes('Login')) {
                    const returnUrl = encodeURIComponent(window.location.pathname + window.location.search);
                    const loginBtn = document.getElementById("goLoginBtn");
                    if (loginBtn) loginBtn.href = `/Account/Login?ReturnUrl=${returnUrl}`;

                    const modalEl = document.getElementById("loginRequiredModal");
                    if (modalEl) bootstrap.Modal.getOrCreateInstance(modalEl).show();
                    else window.location.href = `/Account/Login?ReturnUrl=${returnUrl}`;

                    btnElement.innerHTML = originalContent;
                    btnElement.disabled = false;
                    return;
                }

                if (!res.ok) throw new Error('Lỗi server: ' + res.status);

                // 2. THÊM THÀNH CÔNG -> Đổi icon nút thành dấu check
                btnElement.innerHTML = '<i class="bi bi-check-lg text-success fw-bold fs-4"></i>';

                // 3. Đọc dữ liệu JSON để cập nhật số lượng giỏ hàng trên Navbar
                try {
                    const data = await res.json();
                    if (data.success === false) {
                        alert(data.error || data.message || 'Lỗi thêm giỏ hàng!');
                        btnElement.innerHTML = originalContent;
                        btnElement.disabled = false;
                        return;
                    }
                    if (data.count !== undefined) {
                        const badge = document.getElementById('cartBadge');
                        if (badge) {
                            badge.textContent = data.count;
                            badge.style.display = data.count > 0 ? 'block' : 'none';
                        }
                    }
                } catch (jsonErr) {
                    // Bỏ qua lỗi nếu server không trả về JSON, vì bản chất là đã thêm thành công
                }

                // 4. HIỂN THỊ THÔNG BÁO BÊN GÓC MÀN HÌNH (TOAST)
                const toastEl = document.getElementById('cartToast');
                if (toastEl) {
                    // Dùng getOrCreateInstance để bật Toast chuẩn xác nhất
                    const toast = bootstrap.Toast.getOrCreateInstance(toastEl);
                    toast.show();
                } else {
                    // Fallback: Nếu HTML trang web của bạn lỡ bị thiếu cục div Toast, nó sẽ báo bằng Alert
                    alert("✅ Đã thêm sản phẩm vào giỏ hàng thành công!");
                }

                // 5. Trả lại trạng thái nút bấm sau 1.5 giây
                setTimeout(() => {
                    btnElement.innerHTML = originalContent;
                    btnElement.disabled = false;
                }, 1500);

            } catch (err) {
                console.error('Lỗi AddToCart:', err);
                alert('Lỗi kết nối. Vui lòng F5 tải lại trang!');
                btnElement.innerHTML = originalContent;
                btnElement.disabled = false;
            }
        }

        // ─── 2. WISHLIST (ĐÃ FIX LỖI CLICK & API) ───
        $(function () {
            // Kiểm tra trạng thái lúc tải trang
            $('.wishlist-toggle').each(async function () {
                const btn = this;
                const productId = btn.dataset.productId;
                try {
                    // Cập nhật lại đường dẫn API chuẩn của Razor Pages
                    const res = await fetch(`/Wishlist?handler=Check&productId=${productId}`);
                    const data = await res.json();
                    const icon = btn.querySelector('.wishlist-icon');

                    if (data.isInWishlist) {
                        icon.classList.remove('bi-heart','text-secondary');
                        icon.classList.add('bi-heart-fill','text-danger');
                        btn.title = 'Xóa khỏi Wishlist';
                    } else {
                        icon.classList.remove('bi-heart-fill','text-danger');
                        icon.classList.add('bi-heart','text-secondary');
                        btn.title = 'Thêm vào Wishlist';
                    }
                } catch (e) { console.log('Check wishlist fail:', e); }
            });

            // Xử lý khi nhấn nút
            $(document.body).on('click', '.wishlist-toggle', async function (e) {
                e.preventDefault();
                e.stopPropagation(); // Cực kỳ quan trọng: Ngăn click lan xuống thẻ <a> bên dưới

                const btn = this;
                const icon = btn.querySelector('.wishlist-icon');
                const productId = btn.dataset.productId;

                btn.disabled = true;
                btn.style.transform = 'scale(0.85)';
                setTimeout(() => btn.style.transform = 'scale(1)', 150);

                try {
                    const token = $('input[name="__RequestVerificationToken"]').val();

                    // Cập nhật lại đường dẫn API chuẩn của Razor Pages
                    const res = await fetch(`/Wishlist?handler=Toggle&productId=${productId}`, {
                        method: 'POST',
                        headers: {
                            'RequestVerificationToken': token,
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });

                    // Nếu chưa đăng nhập -> Mở Modal đăng nhập
                    if (res.status === 401) {
                        const returnUrl = encodeURIComponent(window.location.pathname + window.location.search);
                        const loginBtn = document.getElementById("goLoginBtn");
                        if(loginBtn) loginBtn.href = `/Account/Login?ReturnUrl=${returnUrl}`;

                        const modalEl = document.getElementById("loginRequiredModal");
                        if(modalEl) bootstrap.Modal.getOrCreateInstance(modalEl).show();
                        else window.location.href = `/Account/Login?ReturnUrl=${returnUrl}`;
                        return;
                    }

                    if (!res.ok) throw new Error('Network error');
                    const data = await res.json();

                    if (data.success) {
                        // Cập nhật số lượng trên Navbar
                        const badge = document.getElementById('wishlistBadge');
                        if (badge) {
                            badge.textContent = data.count ?? 0;
                            badge.style.display = (data.count ?? 0) > 0 ? 'block' : 'none';
                        }

                        // Đổi màu tim
                        if (data.isAdded) {
                            icon.classList.remove('bi-heart','text-secondary');
                            icon.classList.add('bi-heart-fill','text-danger');
                            btn.title = 'Xóa khỏi Wishlist';
                        } else {
                            icon.classList.remove('bi-heart-fill','text-danger');
                            icon.classList.add('bi-heart','text-secondary');
                            btn.title = 'Thêm vào Wishlist';
                        }

                        // Hiện thông báo góc màn hình
                        const toastEl = document.getElementById('wishlistToast');
                        if (toastEl) {
                            new bootstrap.Toast(toastEl).show();
                        }
                    } else {
                        alert(data.message || 'Lỗi xử lý wishlist');
                    }
                } catch (err) {
                    console.error(err);
                } finally {
                    btn.disabled = false;
                }
            });
        });

        // ─── 3. SCROLL REVEAL ───
        (function () {
            var els = document.querySelectorAll('.sh-reveal-up');
            if (!('IntersectionObserver' in window)) { els.forEach(function (el) { el.classList.add('sh-revealed'); }); return; }
            var obs = new IntersectionObserver(function (entries) {
                entries.forEach(function (e) {
                    if (!e.isIntersecting) return;
                    setTimeout(function () { e.target.classList.add('sh-revealed'); }, parseFloat(e.target.style.animationDelay || '0') * 1000);
                    obs.unobserve(e.target);
                });
            }, { threshold: 0.1 });
            els.forEach(function (el) { obs.observe(el); });
        })();

        // ─── 4. PRICE CHIPS ───
        function setPrice(min, max) {
            var minInp = document.getElementById('minPriceInp');
            var maxInp = document.getElementById('maxPriceInp');
            if (minInp) minInp.value = min > 0 ? min : '';
            if (maxInp) maxInp.value = max < 999999999 ? max : '';
        }

        // ===============================================
        // 5. KHÔI PHỤC SIGNALR (REAL-TIME UPDATE SẢN PHẨM)
        // ===============================================
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/appHub")
            .build();

        // XÓA (DELETE)
        connection.on("ReceiveProductDelete", function (deletedProductId) {
            var productElement = document.getElementById("product-card-" + deletedProductId);
            if (productElement) {
                productElement.style.transition = "all 0.5s ease";
                productElement.style.opacity = "0";
                productElement.style.transform = "scale(0.8)";
                setTimeout(() => productElement.remove(), 500);
            }
        });

        // HÀM VẼ HTML CHO SẢN PHẨM MỚI
        function renderNewProductCard(product) {
            var formattedPrice = product.price.toLocaleString('vi-VN') + ' ₫';
            var imageUrl = product.image ? product.image : 'https://placehold.co/400x400/f8fafc/94a3b8?text=No+Image';

            return `
                <div class="col sh-reveal-up sh-revealed" id="product-card-${product.productId}" style="opacity: 0; transform: scale(0.8); transition: all 0.5s ease;">
                    <div class="sh-card">
                        <div class="sh-card-stripe"></div>
                        <div class="sh-card-img-wrap">
                            <span class="sh-badge-hot"><i class="bi bi-lightning-charge-fill me-1"></i>MỚI</span>
                            <button class="sh-wishlist-btn wishlist-toggle" data-product-id="${product.productId}" title="Thêm vào yêu thích">
                                <i class="bi bi-heart fs-5 wishlist-icon text-secondary"></i>
                            </button>
                            <a href="/Shop/Details/${product.productId}" class="sh-img-link">
                                <img src="${imageUrl}" class="sh-product-img product-img p-img" alt="${product.productName}">
                            </a>
                            <div class="sh-card-overlay"></div>
                            <div class="sh-actions product-actions">
                                <button class="sh-action-btn btn-add-cart" title="Thêm vào giỏ" onclick="addToCart(${product.productId}, this)">
                                    <i class="bi bi-cart-plus"></i>
                                </button>
                                <a href="/Shop/Details/${product.productId}" class="sh-action-btn" title="Xem chi tiết">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </div>
                        </div>
                        <div class="sh-card-body">
                            <div class="sh-cat-tag p-cat">${product.categoryName}</div>
                            <h6 class="sh-product-name">
                                <a href="/Shop/Details/${product.productId}" class="sh-product-link p-name">${product.productName}</a>
                            </h6>
                            <div class="sh-stars">
                                <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-half"></i>
                                <span class="sh-star-val">5.0 (0)</span>
                            </div>
                            <div class="sh-card-foot">
                                <div>
                                    <span class="sh-price p-price">${formattedPrice}</span>
                                    <div class="sh-free-ship"><i class="bi bi-truck me-1"></i>Freeship</div>
                                </div>
                                <button class="sh-cart-quick btn-add-cart" onclick="addToCart(${product.productId}, this)" title="Thêm vào giỏ">
                                    <i class="bi bi-cart-plus"></i>
                                </button>
                            </div>
                        </div>
                        <div class="sh-card-shine"></div>
                    </div>
                </div>
            `;
        }

        // LẮNG NGHE LỆNH SỬA (UPDATE)
        connection.on("ReceiveProductUpdate", function (product) {
            var card = document.getElementById("product-card-" + product.productId);
            var grid = document.getElementById("productGrid");

            // NẾU ADMIN ĐỔI THÀNH ẨN (INACTIVE)
            if (product.status === 0) {
                if (card) {
                    card.style.transition = "all 0.5s ease-out";
                    card.style.opacity = "0";
                    card.style.transform = "scale(0.8)";
                    setTimeout(() => card.remove(), 500);
                }
                return;
            }

            // NẾU ADMIN ĐỔI THÀNH HIỂN THỊ (ACTIVE)
            if (product.status === 1) {
                if (card) {
                    card.querySelector('.p-name').innerText = product.productName;
                    card.querySelector('.p-price').innerText = product.price.toLocaleString('vi-VN') + ' ₫';
                    card.querySelector('.p-img').src = product.image ? product.image : 'https://placehold.co/400x400/f8fafc/94a3b8?text=No+Image';
                    card.querySelector('.p-cat').innerText = product.categoryName;

                    card.querySelector('.sh-card').style.transition = "box-shadow 0.3s";
                    card.querySelector('.sh-card').style.boxShadow = "0 0 20px rgba(25, 135, 84, 0.8)";
                    setTimeout(() => card.querySelector('.sh-card').style.boxShadow = "", 1500);
                }
                else if (grid) {
                    grid.insertAdjacentHTML('afterbegin', renderNewProductCard(product));
                    setTimeout(() => {
                        var newEl = document.getElementById("product-card-" + product.productId);
                        if(newEl) {
                            newEl.style.opacity = "1";
                            newEl.style.transform = "scale(1)";
                        }
                    }, 50);
                }
            }
        });

        // LẮNG NGHE LỆNH THÊM MỚI (CREATE)
        connection.on("ReceiveProductCreate", function (product) {
            if (product.status === 0) return;

            var grid = document.getElementById("productGrid");
            if (grid) {
                grid.insertAdjacentHTML('afterbegin', renderNewProductCard(product));
                setTimeout(() => {
                    var newEl = document.getElementById("product-card-" + product.productId);
                    if(newEl) {
                        newEl.style.opacity = "1";
                        newEl.style.transform = "scale(1)";
                    }
                }, 50);
            }
        });

        connection.start().then(function () {
            console.log("Đã kết nối SignalR - Đang chờ nhận Update/Create/Delete !");
        }).catch(function (err) {
            return console.error(err.toString());
        });
    </script>
}
