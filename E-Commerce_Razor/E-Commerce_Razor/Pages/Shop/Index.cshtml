@page
@model E_Commerce_Razor.Pages.Shop.IndexModel
@{
    ViewData["Title"] = "Cửa hàng";

    // HÀM HELPER: Giữ bộ lọc khi sort trong Razor Pages
    string GetSortUrl(string sortOrder)
    {
        return Url.Page("./Index", new
        {
            searchTerm = Model.SearchTerm,
            categoryId = Model.CategoryId,
            minPrice = Model.MinPrice,
            maxPrice = Model.MaxPrice,
            sortOrder = sortOrder
        });
    }

    var allCats = Model.Categories?.ToList();
    var parentCats = allCats?.Where(c => c.ParentId == null).ToList();
}

<form id="csrf-token-form" class="d-none">
    @Html.AntiForgeryToken()
</form>

<div class="container-fluid bg-primary bg-gradient text-white py-5 mb-5" style="--bs-bg-opacity: .9;">
    <div class="container text-center">
        <h1 class="display-5 fw-bold">Cửa Hàng Trực Tuyến</h1>
        <p class="lead mb-0 opacity-75">Sản phẩm công nghệ & thời trang chính hãng - Giá tốt nhất</p>
    </div>
</div>

<div class="container mb-5">
    <div class="row">
        <div class="col-lg-3 d-none d-lg-block">
            <div class="card border-0 shadow-sm mb-4 sticky-top" style="top: 20px; z-index: 1;">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                    <h5 class="fw-bold"><i class="bi bi-funnel-fill text-primary"></i> Bộ lọc</h5>
                </div>
                <div class="card-body">
                    <form method="get">
                        @if (Model.CategoryId.HasValue)
                        {
                            <input type="hidden" asp-for="CategoryId" />
                        }
                        @if (!string.IsNullOrEmpty(Model.SortOrder))
                        {
                            <input type="hidden" asp-for="SortOrder" />
                        }

                        <div class="mb-4">
                            <label class="form-label fw-bold small text-muted">TỪ KHÓA</label>
                            <div class="input-group">
                                <input type="text" asp-for="SearchTerm" class="form-control" placeholder="Tìm tên sản phẩm...">
                                <button class="btn btn-primary" type="submit"><i class="bi bi-search"></i></button>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold small text-muted">KHOẢNG GIÁ (VNĐ)</label>
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <input type="number" asp-for="MinPrice" class="form-control form-control-sm" placeholder="Thấp nhất">
                                <span>-</span>
                                <input type="number" asp-for="MaxPrice" class="form-control form-control-sm" placeholder="Cao nhất">
                            </div>
                            <button class="btn btn-outline-primary btn-sm w-100" type="submit">Áp dụng</button>
                        </div>
                    </form>

                    <div class="mb-4 mt-4">
                        <label class="form-label fw-bold small text-muted">DANH MỤC</label>
                        <div class="list-group list-group-flush mb-2">
                            <a href="@Url.Page("./Index", new { searchTerm = Model.SearchTerm, minPrice = Model.MinPrice, maxPrice = Model.MaxPrice, sortOrder = Model.SortOrder })"
                               class="list-group-item list-group-item-action border-0 px-0 py-2 fw-bold @(Model.CategoryId == null ? "text-primary" : "text-dark")">
                                <i class="bi bi-grid-fill me-2"></i> Tất cả sản phẩm
                            </a>
                        </div>

                        @if (allCats != null)
                        {
                            <div class="accordion accordion-flush" id="categoryAccordion">
                                @foreach (var parent in parentCats)
                                {
                                    var childCats = allCats.Where(c => c.ParentId == parent.CategoryId).ToList();
                                    bool isActiveParent = (Model.CategoryId == parent.CategoryId);
                                    bool isActiveChild = childCats.Any(c => c.CategoryId == Model.CategoryId);
                                    bool expand = isActiveParent || isActiveChild;

                                    <div class="accordion-item border-0">
                                        <h2 class="accordion-header">
                                            <button class="accordion-button shadow-none px-0 py-2 @(expand ? "" : "collapsed") @(isActiveParent ? "text-primary fw-bold" : "text-dark bg-white")"
                                                    type="button" data-bs-toggle="collapse" data-bs-target="#cat-@parent.CategoryId" aria-expanded="@(expand ? "true" : "false")">
                                                <span onclick="window.location.href='@Url.Page("./Index", new { categoryId = parent.CategoryId, searchTerm = Model.SearchTerm, sortOrder = Model.SortOrder })'; event.stopPropagation();">
                                                    @parent.CategoryName
                                                </span>
                                            </button>
                                        </h2>
                                        <div id="cat-@parent.CategoryId" class="accordion-collapse collapse @(expand ? "show" : "")" data-bs-parent="#categoryAccordion">
                                            <div class="accordion-body py-1 ps-3">
                                                <ul class="list-unstyled mb-0 border-start ps-3">
                                                    @foreach (var child in childCats)
                                                    {
                                                        <li class="mb-1">
                                                            <a href="@Url.Page("./Index", new { categoryId = child.CategoryId, searchTerm = Model.SearchTerm, minPrice = Model.MinPrice, maxPrice = Model.MaxPrice, sortOrder = Model.SortOrder })"
                                                               class="text-decoration-none d-block py-1 @(Model.CategoryId == child.CategoryId ? "text-primary fw-bold" : "text-secondary hover-primary")">
                                                                @child.CategoryName
                                                            </a>
                                                        </li>
                                                    }
                                                </ul>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <div class="text-center mt-3 pt-3 border-top">
                        <a asp-page="./Index" class="btn btn-sm btn-link text-decoration-none text-danger">
                            <i class="bi bi-arrow-counterclockwise"></i> Xóa tất cả bộ lọc
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-9">
            <div class="d-flex justify-content-between align-items-center mb-4 bg-white p-3 rounded shadow-sm border">
                <div>
                    <span class="fw-bold text-dark">Hiển thị @(Model.Products?.Count() ?? 0) sản phẩm</span>
                    @if (!string.IsNullOrEmpty(Model.SearchTerm))
                    {
                        <span class="text-muted ms-1 small">(Tìm kiếm: "<strong>@Model.SearchTerm</strong>")</span>
                    }
                </div>
                <div class="dropdown">
                    <button class="btn btn-white border dropdown-toggle" type="button" data-bs-toggle="dropdown">
                        Sắp xếp: <span class="fw-bold text-primary">@(Model.SortOrder == "price_asc" ? "Giá tăng dần" : "Giá giảm dần")</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow">
                        <li><a class="dropdown-item" href="@GetSortUrl("price_desc")">Giá giảm dần</a></li>
                        <li><a class="dropdown-item" href="@GetSortUrl("price_asc")">Giá tăng dần</a></li>
                    </ul>
                </div>
            </div>

            @if (Model.Products != null && Model.Products.Any())
            {
                <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-4" id="productGrid">
                    @foreach (var item in Model.Products)
                    {
                        <div class="col" id="product-card-@item.ProductId">
                            <div class="card h-100 border-0 shadow-hover product-card position-relative">
                                <div class="position-relative overflow-hidden bg-white border-bottom rounded-top product-img-container">
                                    <span class="badge bg-danger position-absolute top-0 start-0 m-3 z-2 shadow-sm">HOT</span>

                                    <a asp-page="./Details" asp-route-id="@item.ProductId" class="d-block w-100 h-100">
                                        <img src="@(string.IsNullOrEmpty(item.Image) ? "https://placehold.co/400x400?text=No+Image" : item.Image)"
                                             class="card-img-top object-fit-contain w-100 h-100 p-3 product-img p-img"
                                             alt="@item.ProductName">
                                    </a>

                                    <button class="position-absolute top-0 end-0 m-2 btn btn-link text-white shadow-sm rounded-circle wishlist-toggle z-index-5 p-0"
                                            data-product-id="@item.ProductId" title="Thêm vào yêu thích"
                                            style="width: 40px; height: 40px; background: rgba(0,0,0,0.1); backdrop-filter: blur(2px);">
                                        <i class="bi bi-heart fs-5 wishlist-icon transition-all"></i>
                                    </button>

                                    <div class="product-actions position-absolute bottom-0 start-0 w-100 p-3 d-flex justify-content-center gap-2">
                                        <button class="btn btn-light rounded-circle shadow-sm btn-add-cart"
                                                title="Thêm vào giỏ"
                                                onclick="addToCart(@item.ProductId, this)">
                                            <i class="bi bi-cart-plus text-primary fs-5"></i>
                                        </button>
                                        <a asp-page="./Details" asp-route-id="@item.ProductId" class="btn btn-light rounded-circle shadow-sm" title="Xem chi tiết">
                                            <i class="bi bi-eye text-dark fs-5"></i>
                                        </a>
                                    </div>
                                </div>

                                <div class="card-body d-flex flex-column p-3">
                                    <div class="small text-muted text-uppercase mb-1 fw-bold p-cat" style="font-size: 0.75rem;">@item.CategoryName</div>
                                    <h6 class="card-title fw-bold text-truncate mb-2">
                                        <a asp-page="./Details" asp-route-id="@item.ProductId" class="text-decoration-none text-dark hover-primary p-name">
                                            @item.ProductName
                                        </a>
                                    </h6>
                                    <div class="mb-2 text-warning small">
                                        <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-half"></i>
                                    </div>
                                    <div class="mt-auto">
                                        <span class="fw-bold text-primary fs-5 p-price">@item.Price.ToString("N0") ₫</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5 bg-white rounded shadow-sm">
                    <div class="mb-3 opacity-25"><i class="bi bi-box-seam display-1"></i></div>
                    <h4 class="fw-bold">Không tìm thấy sản phẩm nào</h4>
                    <p class="text-muted">Hãy thử thay đổi bộ lọc hoặc từ khóa tìm kiếm.</p>
                    <a asp-page="./Index" class="btn btn-primary px-4 rounded-pill mt-2">
                        <i class="bi bi-arrow-repeat"></i> Xóa bộ lọc & Tải lại
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<div class="toast-container position-fixed top-0 end-0 p-3 mt-5" style="z-index: 9999">
    <div id="cartToast" class="toast align-items-center text-white bg-success border-0 shadow-lg" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body fs-6 fw-bold"><i class="bi bi-check-circle-fill me-2"></i> Đã thêm vào giỏ hàng!</div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
    </div>
    <div id="loginToast" class="toast align-items-center text-bg-warning border-0 shadow-lg" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body">
                Vui lòng đăng nhập để dùng Wishlist.
                <a class="btn btn-sm btn-dark ms-2" id="loginToastBtn" href="#">Đăng nhập</a>
            </div>
            <button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
    </div>
</div>

<div class="modal fade" id="loginRequiredModal" tabindex="-1" aria-labelledby="loginRequiredModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-warning text-white border-0">
                <h5 class="modal-title fw-bold" id="loginRequiredModalLabel"><i class="bi bi-exclamation-triangle-fill me-2"></i>Yêu cầu đăng nhập</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center py-4">
                <div class="mb-3"><i class="bi bi-person-lock fs-1 text-warning"></i></div>
                <h6 class="fw-bold mb-2">Bạn cần đăng nhập để thực hiện chức năng này</h6>
                <p class="text-muted mb-0">Vui lòng đăng nhập để tiếp tục mua sắm</p>
            </div>
            <div class="modal-footer border-0 justify-content-center">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Để sau</button>
                <a href="/Account/Login?returnUrl=@Uri.EscapeDataString(Request.Path)" class="btn btn-primary">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập ngay
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // --- 1. HÀM ADD TO CART (Giữ nguyên) ---
        async function addToCart(productId, btnElement) {
            const originalContent = btnElement.innerHTML;
            btnElement.disabled = true;
            btnElement.innerHTML = '<span class="spinner-border spinner-border-sm text-primary" role="status"></span>';

            const formData = new FormData();
            formData.append('productId', productId);
            formData.append('quantity', 1);

            // Lấy token
            const tokenInput = document.querySelector('#csrf-token-form input[name="__RequestVerificationToken"]');
            const token = tokenInput ? tokenInput.value : '';
            formData.append('__RequestVerificationToken', token);

            try {
                const res = await fetch('/Cart/Add', {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest', 'RequestVerificationToken': token },
                    body: formData
                });

                if (!res.ok) throw new Error('Request failed');
                const data = await res.json();

                if (data.success) {
                    const badge = document.getElementById('cartBadge');
                    if (badge) {
                        badge.textContent = data.count ?? badge.textContent;
                        badge.style.display = (data.count ?? 0) > 0 ? 'block' : 'none';
                    }
                    btnElement.innerHTML = '<i class="bi bi-check-lg text-success fw-bold fs-4"></i>';

                    const toastEl = document.getElementById('cartToast');
                    const toast = new bootstrap.Toast(toastEl);
                    toast.show();

                    setTimeout(() => {
                        btnElement.innerHTML = originalContent;
                        btnElement.disabled = false;
                    }, 1500);
                } else {
                    alert(data.error || 'Có lỗi xảy ra!');
                    btnElement.innerHTML = originalContent;
                    btnElement.disabled = false;
                }
            } catch (err) {
                console.error(err);
                alert('Lỗi kết nối! Vui lòng thử lại.');
                btnElement.innerHTML = originalContent;
                btnElement.disabled = false;
            }
        }

        // --- 2. HÀM WISHLIST (YÊU THÍCH) ---
        $(function() {
            $('.wishlist-toggle').each(async function() {
                const btn = this;
                const productId = btn.dataset.productId;
                try {
                    const res = await fetch(`/Wishlist/Check/${productId}`);
                        const data = await res.json();
                    const icon = btn.querySelector('.wishlist-icon');

                    if (data.isInWishlist) {
                        icon.classList.remove('bi-heart', 'text-white');
                        icon.classList.add('bi-heart-fill', 'text-danger');
                        btn.title = 'Xóa khỏi Wishlist';
                    } else {
                        icon.classList.remove('bi-heart-fill', 'text-danger');
                        icon.classList.add('bi-heart', 'text-white');
                        btn.title = 'Thêm vào Wishlist';
                    }
                } catch(e) { console.log('Check wishlist fail:', e); }
            });

            $(document.body).on('click', '.wishlist-toggle', async function(e) {
                e.preventDefault();
                e.stopPropagation();

                const btn = this;
                const icon = btn.querySelector('.wishlist-icon');
                const productId = btn.dataset.productId;

                btn.disabled = true;
                btn.style.transform = 'scale(0.9)';
                setTimeout(() => btn.style.transform = 'scale(1)', 150);

                try {
                    const token = $('input[name="__RequestVerificationToken"]').val();
                    const res = await fetch(`/Wishlist/Toggle/${productId}`, {
                        method: 'POST',
                        headers: { 'RequestVerificationToken': token }
                    });

                     if (res.status === 401) {
                        const returnUrl = encodeURIComponent(window.location.pathname + window.location.search);
                        document.getElementById("loginToastBtn").href = `/Account/Login?ReturnUrl=${returnUrl}`;
                        bootstrap.Toast.getOrCreateInstance(document.getElementById("loginToast"),
                        { autohide: true, delay: 3500, animation: true }).show();
                        return;
                     }

                    if (!res.ok) throw new Error('Network error');
                    const data = await res.json();

                    if (data.success) {
                        if (data.isAdded) {
                            icon.classList.remove('bi-heart', 'text-white');
                            icon.classList.add('bi-heart-fill', 'text-danger');
                            btn.title = 'Xóa khỏi Wishlist';
                        } else {
                            icon.classList.remove('bi-heart-fill', 'text-danger');
                            icon.classList.add('bi-heart', 'text-white');
                            btn.title = 'Thêm vào Wishlist';
                        }
                    } else {
                        alert(data.message || 'Lỗi xử lý wishlist');
                    }
                } catch(err) {
                    console.error(err);
                } finally {
                    btn.disabled = false;
                }
            });
        });

        // ===============================================
        // 3. SIGNALR: LẮNG NGHE THAY ĐỔI TỪ ADMIN
        // ===============================================
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/appHub")
            .build();

        // XÓA (DELETE)
        connection.on("ReceiveProductDelete", function (deletedProductId) {
            var productElement = document.getElementById("product-card-" + deletedProductId);
            if (productElement) {
                productElement.style.transition = "all 0.5s ease";
                productElement.style.opacity = "0";
                productElement.style.transform = "scale(0.8)";
                setTimeout(() => productElement.remove(), 500);
            }
        });

        // ===============================================
        // HÀM HỖ TRỢ: VẼ HTML CHO SẢN PHẨM MỚI
        // ===============================================
        function renderNewProductCard(product) {
            var formattedPrice = product.price.toLocaleString('vi-VN') + ' ₫';

            // ĐÃ SỬA: Thay /Shop/Details?id=${product.productId} thành /Shop/Details/${product.productId}
            return `
                <div class="col" id="product-card-${product.productId}" style="opacity: 0; transform: scale(0.8); transition: all 0.5s ease;">
                    <div class="card h-100 border-0 shadow-hover product-card position-relative">
                        <div class="position-relative overflow-hidden bg-white border-bottom rounded-top product-img-container">
                            <span class="badge bg-danger position-absolute top-0 start-0 m-3 z-2 shadow-sm">MỚI</span>
                            <a href="/Shop/Details/${product.productId}" class="d-block w-100 h-100">
                                <img src="${product.image}" class="card-img-top object-fit-contain w-100 h-100 p-3 product-img p-img" alt="${product.productName}">
                            </a>
                            <button class="position-absolute top-0 end-0 m-2 btn btn-link text-white shadow-sm rounded-circle wishlist-toggle z-index-5 p-0" data-product-id="${product.productId}" style="width: 40px; height: 40px; background: rgba(0,0,0,0.1); backdrop-filter: blur(2px);">
                                <i class="bi bi-heart fs-5 wishlist-icon transition-all"></i>
                            </button>
                            <div class="product-actions position-absolute bottom-0 start-0 w-100 p-3 d-flex justify-content-center gap-2">
                                <button class="btn btn-light rounded-circle shadow-sm btn-add-cart" onclick="addToCart(${product.productId}, this)">
                                    <i class="bi bi-cart-plus text-primary fs-5"></i>
                                </button>
                                <a href="/Shop/Details/${product.productId}" class="btn btn-light rounded-circle shadow-sm">
                                    <i class="bi bi-eye text-dark fs-5"></i>
                                </a>
                            </div>
                        </div>
                        <div class="card-body d-flex flex-column p-3">
                            <div class="small text-muted text-uppercase mb-1 fw-bold p-cat" style="font-size: 0.75rem;">${product.categoryName}</div>
                            <h6 class="card-title fw-bold text-truncate mb-2">
                                <a href="/Shop/Details/${product.productId}" class="text-decoration-none text-dark hover-primary p-name">${product.productName}</a>
                            </h6>
                            <div class="mb-2 text-warning small">
                                <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-half"></i>
                            </div>
                            <div class="mt-auto">
                                <span class="fw-bold text-primary fs-5 p-price">${formattedPrice}</span>
                            </div>
                        </div>
                    </div>
                </div>
            `;
        }

        // ===============================================
        // LẮNG NGHE LỆNH SỬA (UPDATE) THÔNG MINH
        // ===============================================
        connection.on("ReceiveProductUpdate", function (product) {
            var card = document.getElementById("product-card-" + product.productId);
            var grid = document.getElementById("productGrid");

            // NẾU ADMIN ĐỔI THÀNH ẨN (INACTIVE)
            if (product.status === 0) {
                if (card) {
                    card.style.transition = "all 0.5s ease-out";
                    card.style.opacity = "0";
                    card.style.transform = "scale(0.8)";
                    setTimeout(() => card.remove(), 500);
                }
                return;
            }

            // NẾU ADMIN ĐỔI THÀNH HIỂN THỊ (ACTIVE)
            if (product.status === 1) {
                if (card) {
                    card.querySelector('.p-name').innerText = product.productName;
                    card.querySelector('.p-price').innerText = product.price.toLocaleString('vi-VN') + ' ₫';
                    card.querySelector('.p-img').src = product.image;
                    card.querySelector('.p-cat').innerText = product.categoryName;

                    card.style.transition = "box-shadow 0.3s";
                    card.style.boxShadow = "0 0 20px rgba(25, 135, 84, 0.8)";
                    setTimeout(() => card.style.boxShadow = "", 1500);
                }
                else if (grid) {
                    grid.insertAdjacentHTML('afterbegin', renderNewProductCard(product));
                    setTimeout(() => {
                        var newEl = document.getElementById("product-card-" + product.productId);
                        if(newEl) {
                            newEl.style.opacity = "1";
                            newEl.style.transform = "scale(1)";
                        }
                    }, 50);
                }
            }
        });

        // ===============================================
        // LẮNG NGHE LỆNH THÊM MỚI (CREATE)
        // ===============================================
        connection.on("ReceiveProductCreate", function (product) {
            if (product.status === 0) return;

            var grid = document.getElementById("productGrid");
            if (grid) {
                grid.insertAdjacentHTML('afterbegin', renderNewProductCard(product));
                setTimeout(() => {
                    var newEl = document.getElementById("product-card-" + product.productId);
                    if(newEl) {
                        newEl.style.opacity = "1";
                        newEl.style.transform = "scale(1)";
                    }
                }, 50);
            }
        });

        connection.start().then(function () {
            console.log("Đã kết nối SignalR - Đang chờ nhận Update/Create/Delete !");
        }).catch(function (err) {
            return console.error(err.toString());
        });
    </script>
}

<style>
    /* 1. Hiệu ứng Hover Link */
    .hover-primary:hover {
        color: var(--bs-primary) !important;
        transition: color 0.2s;
    }

    /* 2. Product Card Animation */
    .shadow-hover {
        transition: all 0.3s ease;
        border: 1px solid #eee !important;
    }

        .shadow-hover:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
            border-color: transparent !important;
        }

    /* 3. Zoom ảnh khi hover */
    .product-img {
